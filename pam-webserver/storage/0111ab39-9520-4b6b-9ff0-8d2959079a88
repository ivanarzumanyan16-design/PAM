                                this.mAccessToken);
                return r;
        }
        
        async getUserID() {
                let r = await this.HTTPGet(this.mGetUserIDRequest,
                                this.mAccessToken);
                console.assert(r && r.ok, 'response to metax.getUserID() is not ok');
                r = await r.json();
                return r.user_id;
        }
        
        /**
         * @summary Notify watchers about given uuid update. 
         * @param uuid - must be a valid uuid of existing object in Metax
         * @param type - the type of update, can be 
                   property (for property change), 
                   collection_add(for add element in collection),
                   collection_delete(for delete element from collection)
         * @param id - the id of changed property or collection
         * @param locale - locale in which change was done
         * @param old - the old value of property if there is 
         */
        async notify(uuid, type="property", id, locale, old) {
                const body = { type, id, locale, old }
                const r = await this.HTTPPost(this.mNotifyRequest + uuid, JSON.stringify(body), "application/json",
                                this.mAccessToken);
                return r.status
        }
        
        /**
         * @summary translates property value to given locale. 
         * @param uuid - uuid of object which property we need to translate
         * @param property - if of property which will be translated
         * @param locale - locale to which property will be translated
         */
        async translateProperty(uuid, property, locale) {
                let r = await this.HTTPGet(`${this.mtranslateRequest}${uuid}&property=${property}&locale=${locale}`,
                                this.mAccessToken);
                console.assert(r && r.ok, 'response to metax.translateProperty() is not ok');
                r = await r.json();
                return r.value;
        }
};

metax = new Metax();

export default metax;