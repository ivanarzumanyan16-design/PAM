        <script type="module" content-type="text/javascript">
        
	import mani from '/db/get?id=09431fbd-3295-4805-a888-ac2041b70184';
	import metax from '/db/get?id=0111ab39-9520-4b6b-9ff0-8d2959079a88';
                
                
        async function getJSON(uuid) {
                return metax.get(uuid).then(r => r.json())
                        .catch(e => alert("getJSON: got an error " + e));
        };
                        
        async function saveJSON(data) {
                return await metax.save(data)
                        .catch(e => alert("saveJSON: got an error " + e));
        };
                        
        async function updateJSON(uuid, data) {
                await metax.update(uuid, data, "application/json")
                        .catch(e => alert("updateJSON: got an error " + e));
        };
                
        window.onload = async () => {
                const host = window.location.hostname;
                const port = window.location.port;
                let secure = false;
                if(window.location.protocol == "https:") { 
                        secure = true;
                };
                await metax.connect(host, port, false, secure);
                await mani.connect(metax);
                setupDocumentHeader();
                //redrawWindow(); // window.location.hash has valid uuid, so show its props
                const uuid = window.location.hash.slice(1)
		console.log(uuid)// hash[1] is #, so we slice it away
                if (uuid == null || ! metax.isValidUUID(uuid)) { // the very first URL may have no hash
                       navigateToNode("aea62f74-9622-4c9c-93cf-dcd707e11e43");
		       window.location.hash = "aea62f74-9622-4c9c-93cf-dcd707e11e43";
                } else {
                       redrawWindow(); // window.location.hash has valid uuid, so show its props
                }
        }
        
        window.onpopstate = async () => {
               const uuid = window.location.hash.slice(1); // hash[1] is #, so we slice it away
               if (uuid == null || ! metax.isValidUUID(uuid)) { // the very first URL may have no hash
                      await navigateToNode(uuid);
               } else {
                      redrawWindow(); // window.location.hash has valid uuid, so show its props
               }
        }
                
        // Typically invoked the very first time, when there is no #UUID in URL,
        // otherwise use redrawWindow() which will use current #UUID hash to get object.
        // We also call it from ☰ button-press when hash != "", therefore we don't assert.
	
        async function navigateToNode(uuid) {
                const base = window.location.href.split('#')[0]; 
                console.log(base);
                console.assert(metax.isValidUUID(uuid));
                window.history.pushState(null,null,base + '#' + uuid);
                await redrawWindow();
        }
                
        // TODO: make sure this is SEO friendly, i.e. that robots pick-up the page
        function setupDocumentHeader() {
            mani.windowTitle("Մանի Յաւելուած");
            mani.loadCSS("/db/get?id=40bedcf0-bf66-46c5-906f-43a785dcb9cf");  // g3
            mani.loadCSS("/db/get?id=0b1e4be4-0242-4af9-a8fd-224ae5d26d24");  // g3_colors
            mani.addMeta("description", "Mani Application");
            mani.addMeta("author", "ISRC Foundation, Yerevan Armenia, 2023");
        }
                
        function clearDocumentBody() {
                while (document.body.firstChild) {
                        document.body.removeChild(document.body.firstChild);
                }
        }
                
        function createSideBar(rootObject) {
                let sidebar = mani.sideBarBegin();
                        if(navigator.userAgent.search("Android") != -1) {
                                 mani.width("100%");
                        } else {
                                mani.width("40%");
                        }
                        mani.height("100%")
                        mani.color("black");
                        mani.visible("none");
                        let sidebarFrame = mani.frameBegin();
                                mani.padding("0");
                                mani.headerBegin();
                                        mani.margin("0");
                                        const closeBtn = mani.buttonBegin();
                                                closeBtn.style.float = "left";
                                                mani.margin("12px");
                                                mani.width("40px");
                                                mani.middle();
                                                mani.title("x");
                                                mani.buttonAction(() => {
                                                        sidebar.style.display = "none";
                                                });
                                        mani.buttonEnd();
                                        const selectBtn = mani.buttonBegin();
                                                selectBtn.style.float = "right";
                                                mani.margin("12px");
                                                mani.middle();
                                                mani.title("Select");
                                                mani.disabled(true);
                                                mani.buttonAction(() => {
                                                        sidebar.style.display = "none";
                                                        const obj = document.selectedObject;
                                                        console.assert(obj && "uuid" in obj);
                                                        const uuid = obj.uuid;
                                                        console.assert(metax.isValidUUID(uuid));
                                                        navigateToNode(uuid);
                                                });
                                        mani.buttonEnd();
                                mani.headerEnd();
                                mani.hierarchyViewBegin();
                                        mani.hierarchyViewObject(rootObject);
                                        mani.hierarchyViewOnClick((obj) => {
                                                if (typeof(obj)!="object" || ! ("uuid" in obj)) {
                                                        selectBtn.disabled = true;
                                                        selectBtn.style.opacity = 0.3;

                                                } else {
                                                        document.selectedObject = obj;
                                                        selectBtn.disabled = false;
                                                        selectBtn.style.opacity = 1;
                                                }
                                        });
                                mani.hierarchyViewEnd();
                        mani.frameEnd();
                mani.sideBarEnd();
                return sidebar;
        }
                
        // This is re-rendering the property-editor for current location.hash w/o refreshing page
        async function redrawWindow() {
                document.body.style.backgroundColor = "#f2f2f2";
                //mani.colorScheme("black","white","#368BD6","red");
                //mani.colorScheme("#223f23","white","#005396","rgb(3, 179, 129)", "red");
                mani.colorScheme("black","white","#018786","#018786","#b71c1c");

                //mani.colorScheme("#223f23","white","#189485","rgb(3, 179, 129)", "red");
                clearDocumentBody();
                const uuid = window.location.hash.slice(1); 
                //const uuid = "781c48a1-92d1-41a5-8f42-3146dbd2060d"; 
                console.assert(uuid && metax.isValidUUID(uuid));
                //const object = await getJSON(uuid);
                let object = {};
                for(let k = 0; k < 50; k++) {
                        object = await getJSON(uuid);
                        if(object != "undefined") {
                                break;
                        } 
                }
                console.assert("type" in object && metax.isValidUUID(object.type));
                //const objectType = await getJSON(object.type);
                let objectType = {};
                for(let l = 0; l < 50; l++) {
                        objectType = await getJSON(object.type);
                        if(objectType != "undefined") {
                                break;
                        } 
                }
                console.assert(objectType);
                //console.assert("uuid" in objectType);
                console.assert(objectType.uuid === object.type );
                if (! ("rootObject" in document)) {
                        document.rootObject = object;
                }
                const rootObject = document.rootObject;
                console.assert(typeof(rootObject) === "object" && "uuid" in rootObject);
                console.assert(metax.isValidUUID(rootObject.uuid));
                const sidebar = createSideBar(rootObject);
                const header = mani.headerBegin();
                        mani.buttonBegin();
                                mani.middle();
                                mani.title("☰");
                                mani.margin("12px");
                                mani.width("40px");
                                mani.padding("7px");
                                mani.buttonAction(() => {
                                        sidebar.style.display = "inline";
                                });
                        mani.buttonEnd();
                        mani.labelBegin(); 
                                mani.middle();
                                mani.labelText("«Մանի ՍԻԳ»");
                        mani.labelEnd();
                        /*mani.actionBegin();
                                mani.title("ok");
                                mani.actionMethod("266f20a1-fae7-4775-bb39-ce5b7227bc6f");
                        mani.actionEnd();*/
                mani.headerEnd();
                const p = mani.propertyEditorBegin();
                        mani.className("g3-card");
			mani.id("property-editor");
                        mani.horizontalMargins("auto");
                        mani.verticalMargins("12px");
                        mani.padding("0px 0px 1px");
                        mani.propertyEditorObject(object,rootObject);
                mani.propertyEditorEnd();
        }
                
        </script>

