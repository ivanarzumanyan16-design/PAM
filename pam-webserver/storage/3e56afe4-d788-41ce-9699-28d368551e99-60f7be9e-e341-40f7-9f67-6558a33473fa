ent\r\n#Defaults:%sudo env_keep += \"GPG_AGENT_INFO\"\r\n\r\n# Host alias specification\r\n\r\n# User alias specification\r\n\r\n# Cmnd alias specification\r\n\r\n# User privilege specification\u001b[m\r\n\u001b[31mroot\u001b[m    \u001b[35mALL\u001b[m\u001b[38;5;130m=\u001b[m\u001b[35m(\u001b[m\u001b[35mALL\u001b[m\u001b[35m:\u001b[m\u001b[35mALL\u001b[m\u001b[35m)\u001b[m \u001b[35mALL\u001b[m\u001b[46;172H42,1\u001b[10C20%\u001b[40;1H\u001b[?25h\u001b[?4m"]
