        async __rewrapLiteralProperty(o,t,p) {
                Object.defineProperty(o, p.id, {
                        get() {
                                console.assert(p.id in o);
                                return o[p.id];
                        },
                        set(newValue) {
                                o.$record$[p.id] = newValue;
                        }
                })
        }
        
        async __rewrapNonLiteralProperty(o,t,p) {
                console.assert("id" in p);
                console.assert(typeof(p.id) === "string");
                console.assert
                Object.defineProperty(o, p.id, {
                        get() {
                                console.assert(p.id in o);
                                return this.wrap(o[p.id]);
                        },
                        set(newValue) {
                                o[p.id] = newValue;
                        }
                });         
        }
        
        async __rewrapProperty(o,t,p) {
                console.assert("type" in o);
                console.assert(o.type === t);
                console.assert("type" in t);
                console.assert(t.type === this.Type.Type);
                console.assert("value_type" in p);
                const pValueType = await this.wrap(p.value_type);
                console.assert("type" in pValueType);
                console.assert(pValueType.type === p.Type.Type);
                console.assert("literal" in pValueType);
                console.assert("type" in pValueType.literal);
                console.assert(pValueType.literal.type === this.Type.Boolean);
                if(pValueType.literal === this.Type.Boolean.False) {
                        this.__rewrapNonLiteralProperty(o,t,p);
                } else {
                        console.assert(pValueType.literal === this.Type.Boolean.True);
                        this.__rewrapLiteralProperty(o,t,p);
                }
        }        
                
        async __rewrapCollection(o,t,c) {
        }
                
        async rewrap(o) {
                console.assert("$record$" in o);
                const oRecord = o.$record$;
                for (let i in o) { 
                        delete o[i];
                }
                o.$record$ = oRecord;
                console.assert("uuid" in oRecord);
                const oUUID = oRecord.uuid;
                console.assert(this.metax.isValidUUID(oUUID));
                console.assert("type" in oRecord); 
                const tUUID = oRecord.type;
                console.assert(this.metax.isValidUUID(tUUID));
                const t = await this.wrap(tUUID);
                console.assert("properties" in t);
                await Promise.all(t.properties.map(async p => this.__rewrapProperty(o,t,p)));
                console.assert("collections" in t);
                await Promise.all(t.collections.map(async c =>
                                                        this.__rewrapCollection(o,t,c)));
        }
        
        async wrap(uuid) {
                console.assert(uuid != null);
                let o = this.cache.get(uuid);
                if (o != undefined) {
                        console.assert(this.status === "bootstrapping" 
                                       || this.__checkObject(o));
                        return o;
                }
                const r = await this.__fetchRecord(uuid);
                o = { $record$: r };
                this.cache.put(uuid, o);
                this.rewrap(o);
                return o;
        }
        
