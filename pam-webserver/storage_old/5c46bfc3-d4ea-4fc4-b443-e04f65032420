function __createPropertiesTab(o,t,scope) {
        console.assert(__getContext("mani-notebook-bar"));
        console.assert("properties" in t);
        console.assert(Array.isArray(t.properties));
        const tab = mani.notebookTabBegin();
                mani.tooltip("This tab displays all scalar properties of the object. " +
                       "The nested object collections are displayed in the separate tabs");
                mani.notebookTabTitle("Properties");
                mani.notebookTabRenderContents( () => {
                        const copyScope = new __Scope;
                        for (let i in scope) { copyScope[i] = scope[i]; }
                        scope.previous = copyScope;
                        scope.tab = "Properties";
                        t.properties.forEach(propSpec => {
                                if (__isVisible(propSpec) || !("visible" in propSpec)){
                                        __createPropertyLabelAndEntryField(propSpec,o,t,
                                                                                   scope);
                                }
                        });
                });
        mani.notebookTabEnd();        
        console.assert(scope.tab != "");
        if (scope.tab == "Properties") {
                tab.click();
                // undo the extra push due to click
                scope.previous = scope.previous.previous; 
        }
}

function __createNewVostanObject(typeSpec) {
        console.assert("uuid" in typeSpec);
        console.assert("type" in typeSpec);
        console.assert(typeSpec.type === __typeUUID); 
        const newObject = {};
        typeSpec.properties.forEach((i) => {
                console.assert("id" in i);
                console.assert("value_type" in i);
                console.assert("mandatory" in i);
                if (__isMandatory(i)) {
                        newObject[i.id] = "";
                }
        });
        console.assert("name" in typeSpec);
        console.assert("name" in newObject);
        console.assert("id" in typeSpec);
        console.assert("id" in newObject);
        newObject.name = "New " + typeSpec.name;
        newObject.id = "New " + typeSpec.id;
        //newObject.value_type = typeSpec.value_type
        console.assert("type" in newObject);
        newObject.type = typeSpec.uuid;
        console.assert("uuid" in newObject);
        newObject.uuid = "Pending save in Metax...";
        typeSpec.collections.forEach((j) => {
                console.assert("id" in j);
                console.assert("element_type" in j);
                newObject[j.id] = [];
        });
        return newObject;
}

function __saveNewCollectionElementToMetax(newElement,o,collectionSpec) {
        console.assert("element_type" in collectionSpec);
        console.assert("type" in newElement);
        console.assert(collectionSpec.element_type == newElement.type);
        console.assert("id" in collectionSpec);
        console.assert(collectionSpec.id in o);
        console.assert("uuid" in newElement);
        console.assert(newElement.uuid === "Pending save in Metax...");
        return mani.metax.save(newElement).then(uuid => {
                newElement.uuid = uuid;
                o[collectionSpec.id].push(uuid);
                return Promise.all( [
                        mani.metax.update(newElement.uuid, JSON.stringify(newElement)),
                        mani.metax.update(o.uuid, JSON.stringify(o))
                ])
                .then(r => newElement)
                .catch(e => { // todo - keep trying
                        console.error(`failed to update ${uuid} in metax: ${e}`);
                        console.warn(`Could not update ${uuid} in Metax. Check Network...`);
                });
        }).catch(e => { 
                console.error(`failed to save new ${newElement} in metax: ${e}`);
                console.warn(`Could not save new record ${newElement} in Metax. Check Network...`);
        });
}

