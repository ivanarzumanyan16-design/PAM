function __saveLiteralProperty(obj, field, newValue, stringEdit, propSpec, scope) {
        const o = (scope.embeddedObject == null) ? obj : scope.embeddedObject;
        console.assert((field in o) || !__isMandatory(propSpec));
        __pushContext(stringEdit);
                mani.disabled(true);
                mani.editStringValue(newValue + " Saving... ");
        __popContext(stringEdit);
        o[field] = newValue;
        mani.metax.update(scope.object.uuid, JSON.stringify(scope.object))
        .then(r => {
                __pushContext(stringEdit);
                        __setTextColors();
                        mani.editStringValue(newValue);
                        mani.disabled(false);
                __popContext(stringEdit);
        }).catch(e => {
                __pushContext(stringEdit);
                        __setErrorColors();
                        mani.editStringValue(newValue + 
                                " Error: Failed to submit the update," +
                                " please check Network and retry... ");
                        mani.disabled(false);
                __popContext(stringEdit);
        });
        return newValue;
}

