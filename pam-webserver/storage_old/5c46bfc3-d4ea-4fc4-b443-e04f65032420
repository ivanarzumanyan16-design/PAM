                                        let prop = __createPropertyEntryField(v,j,object,scope);
                                        let propobj = {element: prop, vt: v}
                                        values.push(propobj);
                                        __popContext(scope.frame);
                                })
                        })
                });
        } else if (scope.previous != null) {
                __recreatePropertyEditor(scope.previous);
        }
}

function __propertyEditorCalendarViewHandler(y,m,scope,c) {
	console.log(scope);
        let daysInWeek = ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'];
        __pushContext(scope.frame);
        const lc = scope.frame.lastChild;
        if(lc.tagName == "TABLE" && lc.style.display != "none") {
