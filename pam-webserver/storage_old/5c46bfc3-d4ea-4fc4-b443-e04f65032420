            mani.tableCellEnd();
        }
        mani.tableRowEnd();
        let start = new Date(y,m,1); 
        start.setDate(start.getDate() - start.getDay()); 
        let finish = new Date(y,m+1,0); 
        finish.setDate(finish.getDate() + (7-finish.getDay())); 
        let current = new Date(start.toDateString()); 
        let str = []; 
        for (current.setDate(current.getDate()+1); current <= finish; 
                                             current.setDate(current.getDate()+1)) {       
            str.push(current.getDate());
            if (current.getDay() == 0) {
