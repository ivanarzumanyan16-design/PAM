function __isType(tSpec) {
        return (tSpec.type === __typeUUID);
}

// TODO: this assumes that is_mandatory defaults to false for prop-spec!!!
//        need to add corresponding assertion
function __isLiteralType(tSpec) {
        console.assert(__isType(tSpec));
        if ("literal" in tSpec) { 
                console.assert(-1 != [__falseUUID, __trueUUID].indexOf(tSpec.literal));
                return tSpec.literal === __trueUUID;
        }
        return false; 
}

// TODO: add better checks or at least more (e.g. when Owner is added to backpoint to Type)
function __isProperty(propSpec) {
        return ("id" in propSpec) && ("name" in propSpec) && ("value_type" in propSpec);
}

function __isVisible(tSpec) {
        if ("visible" in tSpec) { 
                return tSpec.visible === __trueUUID;
        }
        return false; 
}

function __isMandatory(propSpec) {
        console.assert(__isProperty(propSpec));
        if ("mandatory" in propSpec) { 
                console.assert(-1 != [__falseUUID, __trueUUID].indexOf(propSpec.mandatory));
                return propSpec.mandatory === __trueUUID;
        }
        return false; // TODO: this assumes that is_mandatory defaults to false for prop-spec!!!
}

function __hasDefaultValue(propSpec) {
        console.assert(__isProperty(propSpec));
        return "default_value" in propSpec;
}

function __getDefaultValue(propSpec) {
        console.assert(__isProperty(propSpec));
        console.assert(__hasDefaultValue(propSpec));
        return propSpec.default_value;
}

function __hasPropertyValue(o, id) {
        console.assert(typeof(id) === "string");
        console.assert(id.length > 0);
        return (id in o) && (o[id] != "") && (o[id] != null);
}

function __hasProperty(o, id) {
        console.assert(typeof(id) === "string");
        console.assert(id.length > 0);
        return (id in o) && (o[id] != null);
}

// TODO: many of these should turn into permissive mode error-objects attached to the O
// e.g. VOSTAN_ASSERT("object", "condition", "error-report") should do the job
function __setDefaultValueIfMissing(o, propSpec) {
        console.assert(__isProperty(propSpec));
        console.assert("id" in propSpec);
        const id = propSpec.id;
        console.assert(typeof(id) === "string");
        console.assert(id.length > 0);
        const mandatory =  __isMandatory(propSpec);
        console.assert(__hasPropertyValue(o,id) || !mandatory);
        if (!__hasPropertyValue(o,id) && __hasDefaultValue(propSpec)) {
                o[id] = __getDefaultValue(propSpec);
        }
}

