        __createHierarchyPropertyNodes(tree, o,t) {
                console.assert(typeof(t) === "object");
                console.assert(typeof(o) === "object");
                console.assert("uuid" in t);
                console.assert(!("type" in o) || (o.type === t.uuid));
                console.assert("properties" in t);
                console.assert(Array.isArray(t.properties));
                t.properties.forEach(p => {
                        console.assert("value_type" in p);
                        console.assert("name" in p);
                        console.assert("id" in p);
                        console.assert(p.id in o || !__isMandatory(p));
                        console.assert(this.metax.isValidUUID(p.value_type));
                        if (p.id in o) {
                                this.__createHierarchyNodeForProperty(p,tree,o,t);
                        }
                });
