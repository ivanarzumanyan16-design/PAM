function __pushContext(e) { 
        console.assert(e && e.name, "need a valid Element to push into Mani stack");
        console.assert(e.name in __maniTagToHTML, `Unexpected Mani Tag ${e.name}`);
        __maniObjectStack.push(e); 
}

// for safety we expect the caller to know what tag is expected
function __popContext(e) { 
        console.assert(e);
        console.assert(e.name);
        console.assert(e === __getStackTop());
        __maniObjectStack.pop();
}

// unsafe version - its better to use __getContext
function __getStackTop() {
        console.assert(__maniObjectStack);
        console.assert(__maniObjectStack.length > 0, "object stack should never be empty");
        const node = __maniObjectStack[__maniObjectStack.length - 1];
        return node;
}

// for safety we expect the caller to know what tag is expected
function __getContext(maniTag) {
        const node = __getStackTop();
        console.assert(node.name == maniTag, `was expecting ${maniTag}, got ${node.name} in stack`);
        return node;
}

