function __createPropertyEntryField(valueType,propSpec,o,scope) {
        console.assert("values" in valueType);
        if (__isLiteralType(valueType)) {
                switch(valueType.uuid) {
                        case __uuidTypeUUID : // "Vostan.Type.UUID":
                                if (propSpec.id === "uuid") {
                                        return __createStringPropertyEntryField(o, propSpec, scope);
                                } else { 
                                        return __createObjectPropertyEntryField(
                                                o, propSpec,  valueType, scope
                                        ); 
                                }
                                break;
                        case "71b30d14-59f8-482d-993d-c913e8737f9e" : // "Vostan.Type.String":
                                return __createStringPropertyEntryField(o, propSpec, scope);
                                break;
                        case "96ec3148-fcf1-4a38-b303-0f8ad2b95137" : // "Vostan.Type.Text":
                                return __createTextPropertyEntryField(o, propSpec, scope);
                                break;
                        case "5769ebe4-a623-4df7-b9bc-ea85d48b7ef5" : // "Vostan.Type.Date":
                                return __createDatePropertyEntryField(o, propSpec, scope);
                                break;
                        case "44be8478-ad50-4602-92e8-7175ee05ef1f" : // "Vostan.Type.Number":
                                return __createNumberPropertyEntryField(o, propSpec, scope);
                                break;
                        case "339a37a8-8185-4b35-8a96-89784de4c2de" : // "Vostan.Type.Image":
                               return __createIconPropertyEntryField(o, propSpec.id, scope);
                               break;
                        case "f96ff257-1395-4cff-a99b-5b55ae6f8e87" : // "Vostan.Type.Teseract":
                               return __createIconPropertyWithTeseractEntryField(o, propSpec.id, scope);
                               break;
                        case "5a6010e0-f920-4755-bba3-b78f90941701" : // "Vostan.Type.Video":
                               return __createVideoPropertyEntryField(o, propSpec.id, scope);
                               break;
                        case "1e2ae2a1-a9ca-478a-aec7-26c80f7d80f4" : // "Vostan.Type.Audio":
                               return __createAudioPropertyEntryField(o, propSpec.id, scope);
                               break;
                        /*
                        case "621f9c89-29d4-43e1-a3ac-bfec09dcf128" ://"Vostan.Type.External":
                               return __createExternalTextPropertyEntryField(o, propSpec.id, scope);
                               console.log("if");
                               break;
                        case "7de34615-762f-4c23-894b-8ccd24f9dbab" ://"Vostan.Type.Calendar":
                               __createScheduler(o, propSpec.id, scope);
                               break;
                        */
                        case __boolUUID : // "Vostan.Type.Boolean":
                                return __createBooleanPropertyEntryField(o, propSpec, scope);
                                //__createStringPropertyEntryField(o, propSpec, scope);
                                break;
                        default:
                                console.assert(false, "Unexpected literal type " +
                                               JSON.stringify(valueType));
                                return __createStringPropertyEntryField(o, propSpec, scope);
                }
        } else if (valueType.values.length > 0 && valueType.uuid != "3e76b8ff-9063-4052-b67a-ecd43302d269") {
                console.assert("uuid" in valueType);
                if(valueType.uuid === __boolUUID) {
                        return __createBooleanPropertyEntryField(o, propSpec, scope);
                } else {
                        return __createEnumPropertyEntryField(o, propSpec, valueType, scope);
                }
        } else if(valueType.uuid == "3e76b8ff-9063-4052-b67a-ecd43302d269") {
                //__createEnumPropertyEntryField(o, propSpec, valueType, scope);
                return __createExternalTextPropertyEntryField(o, propSpec, valueType,  scope);  
        } else  { // else-if... also separatelyprop handle booleans, enums, date-types and images
                 return __createObjectPropertyEntryField(o, propSpec, valueType, scope); 
                // VAHAGN, temporarily
                //__createStringPropertyEntryField(o, propSpec, scope); // using string for now
        }
}

