        console.assert("object" in scope);
        console.assert(n in scope.object);
        console.assert(Array.isArray(scope.object[n]));
        console.assert("kind" in cSpec);
        if (cSpec.kind == __compositionKindUUID) { 
                __renderCompositionElements(cSpec, scope);
        } else if (cSpec.kind == __embeddedKindUUID) {
                __renderEmbeddedCollectionElements(cSpec, scope);
        } else  {
                console.assert(cSpec.kind == __ownedKindUUID, 
                       `unsupported collection kind ${cSpec.kind} in ${scope.object.uuid}`);
                __renderOwnedCollectionElements(cSpec, scope);
        }
