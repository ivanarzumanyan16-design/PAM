function __chooserSelectButtonCallback(o, propSpec, pValue, scope) {
        o[propSpec.id] = pValue.uuid;
        if ("uuid" in o) {
                mani.metax.update(o.uuid, JSON.stringify(o))
                .then(r => {
                        __propertyEditorBackButtonHandler(scope);
                })
        } else { 
                console.assert("uuid" in scope.object);
                mani.metax.update(scope.object.uuid, JSON.stringify(scope.object))
                .then(r => {
                        __propertyEditorBackButtonHandler(scope);
                })

        }
}

function  __chooserSelectNodeCallback(o,  propSpec,  pValue, selectButton, scope) {
        console.assert(o && "id" in propSpec && propSpec.id in o);
        console.assert( ("uuid" in o && scope.object === o) ||
                       ( !("uuid" in o) && (scope.embeddedObject === o) ) );
        // console.assert(!__isLiteralType(propSpec.value_type)); // not to get the vType obj
        console.assert("value_type" in propSpec);
        let valueIsAcceptable = false;
        if (typeof(pValue)==="object" && "uuid" in pValue) { 
                console.assert("type" in pValue);
                        if (pValue.type === propSpec.value_type) {
                        valueIsAcceptable = true;
                }
        }
        __pushContext(selectButton);
                if (valueIsAcceptable) {
                        mani.disabled(false);
                        mani.buttonAction(() => {
                                __chooserSelectButtonCallback(o,propSpec,pValue,scope);
                        });
                } else { 
                        mani.disabled(true);
                        mani.buttonAction( ()=> {
                                console.warn("This button should be disabled (bug!)");
                        });
                }
        __popContext(selectButton);
        console.assert(!valueIsAcceptable ||
                       "uuid" in pValue && mani.metax.isValidUUID(pValue.uuid));
}
        
