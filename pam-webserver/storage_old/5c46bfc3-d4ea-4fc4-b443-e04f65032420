function __createTabForCollection(cSpec, scope) {
        console.assert(__getContext("mani-notebook-bar"));
        console.assert("id" in cSpec);
        const n = cSpec.id;
        console.assert(typeof(n)==="string");
        console.assert(n.length > 0, `id is empty in ${JSON.stringify(cSpec)}`);
        const tab = mani.notebookTabBegin();
                console.assert("object" in scope);
                if (! (n in scope.object)) {
                        console.warn(`${scope.object.uuid} is missing a collection ${n}. adding`);
                        scope.object[n] = [];
                }
                console.assert(n in scope.object);
                console.assert("name" in cSpec);
                console.assert(typeof(cSpec.name)==="string");
                console.assert(cSpec.name.length > 0);
                mani.notebookTabTitle(cSpec.name);
                if (cSpec.description) {
                        mani.tooltip(cSpec.description);
                }
                mani.notebookTabRenderContents(() => {
                        const copyScope = new __Scope;
                        for (let i in scope) { copyScope[i] = scope[i]; }
                        scope.previous = copyScope;
                        scope.tab = n;
                        __renderCollectionTabContents(cSpec, scope); 
                });
        mani.notebookTabEnd();
        if (scope.tab == n) {
                tab.click();
                scope.previous = scope.previous.previous; // undo the extra push due to click
        }
}

