function __propertyEditorBackButtonHandler(scope) {
        const prev = scope.previous;
        //console.assert(prev != null); fix later 
        if(scope.functionObject != null) {
                const object = {};
                const values = [];
                mani.metax.get(scope.functionObject.function).then(i => i.json()).then(i => {
                        const newScope = new __Scope;
                        for (let i in scope) {
