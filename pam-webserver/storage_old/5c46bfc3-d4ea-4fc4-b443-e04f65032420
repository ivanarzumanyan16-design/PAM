                        while (scope.frame.children.length > 1) {
                                scope.frame.removeChild(scope.frame.lastChild);
                        }
                        const body  = i.body;
                        i.arguments.forEach((j) => {
                                //object[j.name] = "";
                                mani.metax.get(j.value_type).then(v => v.json()).then(v => {
                                        __pushContext(scope.frame);
                                        mani.padding("20px");
