        addMeta(n, c) {
            console.assert(typeof(n)==="string");
            console.assert(typeof(c)==="string");
            const m = document.createElement('meta');
            m.name = n;
            m.content = c;
            const h = document.getElementsByTagName('head');
            console.assert(h.length == 1, "Document must have exactly one head element");
            h[0].append(m);
        }

        loadJS(u) {
            console.assert(typeof(u)==="string");
            const s = document.createElement('script');
            s.src = u;
            //s.type = 'text/javascript';
            const h = document.getElementsByTagName('head');
            console.assert(h.length == 1, "Document must have exactly one head element");
            h[0].append(s);
        } 


        loadCSS(u){
            console.assert(typeof(u)==="string");
            var s = document.createElement('link');
            s.href = u;
            s.type = 'text/css';
            s.rel = 'stylesheet';
            const h = document.getElementsByTagName('head');
            console.assert(h.length == 1, "Document must have exactly one head element");
            h[0].append(s);
        }

        loadTheme(theme) {
                console.assert(typeof(theme) === "string");
                console.assert(theme != null);
                this.loadCSS(theme);
                console.assert(__getStackTop() === document.body);
