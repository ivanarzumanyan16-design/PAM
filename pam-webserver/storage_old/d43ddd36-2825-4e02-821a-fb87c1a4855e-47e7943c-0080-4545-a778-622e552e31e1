                if (t.uuid === __uuidTypeUUID) {
                        console.assert("type" in o);
                        console.assert(this.metax.isValidUUID(o.type));
                        this.getJSON(o.type).then(type => {
                                this.__createHierarchySubtree(
                                                prefix,o,type,node,paragraph);
                        }).catch(e => console.warn(`failed to get ${o.type} from Metax: ${e}`));
                        return;
                }
                /**/ // end dirty hack - remove this section to recover regular UUID handling 
                console.assert(!("type" in o) || (t.uuid === o.type) || t.uuid === __uuidTypeUUID);
                console.assert("name" in o);
                console.assert(typeof(o.name) === "string" && o.name.length > 0 ||
                               typeof(o.name) === "object" && Object.keys(o.name).length > 0);
                __pushContext(node);
                        __pushContext(paragraph);
                                this.title("▸ " + prefix + mani.getLiteralValue(o,"name"));
                                this.buttonAction( ()=> {
                                        if (this.__treeNodeIsExpanded(node)) {
                                                this.__collapseTreeNode(node,paragraph,prefix+mani.getLiteralValue(o,"name"));
                                        } else {
                                                this.__expandTreeNode(prefix,node,paragraph,o,t);
                                        }
