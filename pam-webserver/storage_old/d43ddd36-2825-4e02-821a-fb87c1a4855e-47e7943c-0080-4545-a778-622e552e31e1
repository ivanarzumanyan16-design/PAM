                                if (__isAutomaticVersionControlEnabled(propspec)) {
                                        await __commitPropertyCurrentVersion(o, propspec)
                                }
                        })
                        .catch(e => {
                                __pushContext(extText);
                                        __setErrorColors();
                                        extText.textContent = 
                                                mani.getLiteralValue("Error while saving in Metax:" ) + e +
                                        extText.textContent;
                                __popContext(extText);
                        });
        } else {
                mani.metax.save(v, currentType)
                .then(async u => {
                        console.assert(mani.metax.isValidUUID(u));
                        el.body = u;
                        el.mime = currentType;
