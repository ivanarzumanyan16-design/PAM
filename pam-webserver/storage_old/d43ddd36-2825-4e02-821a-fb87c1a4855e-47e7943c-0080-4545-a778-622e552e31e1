function __createPropertyLabelAndEntryField(propSpec,o,t,scope) {
        console.assert("value_type" in propSpec);
        const showOnNextRow = (propSpec.value_type != __boolUUID); 
        let row = mani.rowBegin();
                mani.margin("12px 0 0 0");
                __createPropertyLabel(o, propSpec);
                if (__isAutomaticVersionControlEnabled(propSpec)) {
                        __createVersionControlButtons(o, propSpec, true, scope);
                } else if (__isManualVersionControlEnabled(propSpec)) {
                        __createVersionControlButtons(o, propSpec, false, scope);
                }
        mani.rowEnd();
        if (showOnNextRow) { 
                row =  mani.rowBegin();
                        mani.margin("0 0 12px 0");
                mani.rowEnd();
        }
        if (o.type === __versionControlItemTypeUUID && propSpec.id === "value") {
                propSpec.value_type = scope.versionControlPropertySpec.value_type;
        }
        __getPropertyValueType(propSpec, scope).then(valueType => {
                if (!valueType) {
                        __pushContext(row);
                                __createStringPropertyEntryFieldWithError(
                                        "Value type is not specified", o, propSpec, scope
                                );
                        __popContext(row);
                        return;
                }
                __pushContext(row);
                        __createPropertyEntryField(valueType,propSpec,o,scope)
                __popContext(row);
        }).catch(err => {
                __pushContext(row);
                        __createStringPropertyEntryFieldWithError(
                                err, o, propSpec, scope
                        );
                __popContext(row);
        });
}

