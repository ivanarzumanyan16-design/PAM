class __Scope {
        constructor() {
                this.rootObject = null; // the outermost object (topmost) used for search in selectors
                this.rootObjectType = null; // the outermost object (topmost) used for search in selectors
                this.object = null;
                this.objectType = null;           // will always point to the typeSpec of object
                this.embeddedObject = null;       // if not null then this is the actual object
                this.embeddedObjectType = null;   // type-spec of the embeddedObject
                this.embeddedCollectionSpec = null; // collection where embedded items are stored
                this.functionObject = null; // object for keeping function arguments
                this.tab = "";            // tab navigation goes into history - default to first tab
                this.frame = null;        // top-frame of the property editor
                this.previous = null;     // previous scope - for "Back" function implementation
                this.onChangeObject = () => {} // notifier for mani.propertyEditorOnChangeObject
                this.notify = false; // boolean value for sending notifications on update
        };
        
        async initialize(o) {
                this.object = o;
                console.assert("type" in o);
                this.objectType = await mani.getJSON(o.type)
                        .catch(e => console.warn(`failed to fetch ${o.type}. Error: ${e}. `+ 
                                          "Please check the network and retry..."));
                console.assert("rootObjectType" in this);
               // console.assert(this.rootObjectType == null);
                console.assert("rootObject" in this);
                console.assert(this.rootObject != null);
                console.assert("type" in this.rootObject);
                console.assert(mani.metax.isValidUUID(this.rootObject.type));
                this.rootObjectType = await mani.getJSON(this.rootObject.type)
                .catch(e => console.warn(`failed to fetch ${this.rootObject.type}. Error: ${e}. `+
                                  "Please check the network and retry...")
                      );
                this.notify = this.objectType.enable_notifier === __trueUUID;
                console.assert(this.object != null);
                console.assert(this.objectType != null);
                console.assert(this.frame != null);
                return this;
        }
        
        async pushObject(o,prevScope) {
                for (let i in prevScope) { this[i] = prevScope[i]; }
                this.previous = prevScope;
                this.tab = "Properties";
                this.embeddedObject = null;
                this.embeddedCollectionSpec = null;
                await this.initialize(o);
                console.assert(this.object != null);
                console.assert(this.objectType != null);
                console.assert(this.frame != null);
                this.notify = this.objectType.enable_notifier === __trueUUID;
                return this;
        }
        
        async pushEmbeddedObject(e,cSpec,prevScope) {
                await this.pushObject(prevScope.object, prevScope);
                this.embeddedObject = e;
                this.embeddedCollectionSpec = cSpec;
                console.assert("element_type" in cSpec);
                console.assert(mani.metax.isValidUUID(cSpec.element_type));
                this.embeddedObjectType = await mani.getJSON(cSpec.element_type)
                        .catch(e => console.warn(
                                `failed to fetch ${cSpec.element_type}. Error: ${e}. `+
                                "Please check the network and retry..."));
                return this;
        }
        
}

const listeners = {};

async function __setupListenersForObject(scope) {
        const updateCb = () => { 
                mani.getJSON(scope.object.uuid).then(obj => {
                        if (JSON.stringify(obj) !== JSON.stringify(scope.object)) {
                                scope.object = obj;
                                __recreatePropertyEditor(scope); 
                        }
                });
        }
        await removeAllListeners();
        listeners[scope.object.uuid] = updateCb;
        await mani.metax.registerListener(scope.object.uuid, updateCb);
        console.log("Listener successfully added", scope.object.uuid);
}

async function removeAllListeners() {
        const uuids = Object.keys(listeners);
        for (let u of uuids) {
                await mani.metax.unregisterListener(u, listeners[u])
                        .catch(e => {
                                console.log("Failed to remove listener for " + u, e);
                        })
                delete listeners[u]
                console.log("Listener successfully removed", u);
        }
}

function __recreatePropertyEditor(scope) {
        console.assert("frame" in scope);
        console.assert("name" in scope.frame);
        console.assert(scope.frame.name == "mani-frame");
        __setupListenersForObject(scope);
        __pushContext(scope.frame);
        __removeContents(scope.frame);
        __createPropertyEditorHeader(scope);
        if (json_editor === false) {
                __createPropertyEditorMethodButtons(scope);
                __createPropertyEditorTabs(scope);
        } else {
                __createJsonEditorTab(scope);
        }
        console.assert("onChangeObject" in scope);
