function scopeTabForCalendar(obj, c, scope) {
        mani.getJSON(obj.type).then(objt => {
                if ( c == "Properties" ) {
                        for (let i of objt.collections) {
                                findElementsWithDatePropertie(i, obj, scope);
                        }
                } else {
                        for (let i of objt.collections) {
                                if (i.id == c) {
                                        findElementsWithDatePropertie(i, obj, scope)
                                }
                        }
                } 
        })
}
function findElementsWithDatePropertie(c, obj, scope) {
        let dateUUID = "5769ebe4-a623-4df7-b9bc-ea85d48b7ef5";
        let timeUUID = "e8beb300-242c-48e3-8b26-f5d225380332";
        if (!c.element_type) return false
        __getCollectionElementType(c, scope.object, scope.embeddedObject)
        .then(async elt => {
                for ( let p of elt.properties) {
                        if (p.value_type == dateUUID) {
                                if ( !scope || scope.frame.lastChild.lastChild.id == "month_calendar") {
                                        obj[c.id].forEach(async item => {
                                                var el;
                                                if (c.kind == __embeddedKindUUID) {
                                                        el = item;
                                                } else {
                                                        el = await mani.getJSON(item);
                                                }
                                                if (p.id == "from_date") {
                                                        if (!el[p.id]) return
                                                        addEventOnCalendar(el, el[p.id], scope, null, "month", "start");
                                                        let start = new Date(el[p.id]);
                                                        if (!el["to_date"]) return
                                                        let end = new Date(el["to_date"]);
                                                        for (start.setDate(start.getDate() + 1); start < end; start.setDate(start.getDate() + 1)) {
                                                                let date = [start.getFullYear(), ("0" + (start.getMonth() +1)).slice(-2), ("0" + start.getDate()).slice(-2)].join("-")
                                                                addEventOnCalendar(el, date, scope, null, "month", "middle");
                                                        }
                                                        addEventOnCalendar(el, el["to_date"], scope, null, "month", "finish");
                                                        return
                                                }
                                                if (p.id === "to_date") return
                                                addEventOnCalendar(el, el[p.id], scope, null, "month");
                                        
                                        });
                                } else {
                                        obj[c.id].forEach(async item => {
                                                var el;
                                                if (c.kind == __embeddedKindUUID) {
                                                        el = item;
                                                } else {
                                                        el = await mani.getJSON(item);
                                                }
                                                const timeProp = elt.properties.find(p => p.value_type === timeUUID);
                                                const time = timeProp ? el[timeProp.id] : null;
                                                if (p.id == "from_date") {
                                                        if (!el[p.id]) return
                                                        addEventOnCalendar(el, el[p.id], scope, time, "week", "start");
                                                        let start = new Date(el[p.id]);
                                                        if (!el["to_date"]) return
                                                        let end = new Date(el["to_date"]);
                                                        for (start.setDate(start.getDate() + 1); start < end; start.setDate(start.getDate() + 1)) {
                                                                let date = [start.getFullYear(), ("0" + (start.getMonth() +1)).slice(-2), ("0" + start.getDate()).slice(-2)].join("-")
                                                                addEventOnCalendar(el, date, scope, time,"week", "middle");
                                                        }
                                                        addEventOnCalendar(el, el["to_date"], scope, time, "week", "finish");
                                                        return
                                                }
                                                if (p.id === "to_date") return
                                                if (el["from_time"]) {
                                                        const startTime = new Date(el[p.id] + " " + el["from_time"]);
                                                        addEventOnCalendar(el, el[p.id], scope, el["from_time"], "week", "start");
                                                        if (!el["to_time"]) return
                                                        const endTime = new Date(el[p.id] + " " + el["to_time"]);
                                                        const hourInMiliseconds = 60 * 60 * 1000;
                                                        for (let t = new Date(startTime.setTime(startTime.getTime() + hourInMiliseconds)); t.getTime() < endTime.getTime(); t.setTime(t.getTime() + hourInMiliseconds)) {
                                                                const middleTime = ('0' + t.getHours()).slice(-2) + ':' + ('0' + t.getMinutes()).slice(-2);
                                                                addEventOnCalendar(el, el[p.id], scope, middleTime, "week", "middle");
                                                        }
                                                        addEventOnCalendar(el, el[p.id], scope, el["to_time"], "week", "finish");
                                                        return
                                                }
                                                addEventOnCalendar(el, el[p.id], scope, time, "week");
                                        });
                                }
                        }
                }
        })
}
async function addEventOnCalendar(el, v, scope, t = "", calendar, type = null) {
        var appendTo;
        var count;
        if ( calendar == "month") {
                if (v) appendTo = document.getElementById(v);
                if (appendTo) appendTo = document.getElementById(v).lastChild;
                count = 3;
        } else if ( calendar == "week") {
                count = 2;
                if (!t) {
                        if (v) appendTo = document.getElementById(v);
                } else {
                        appendTo = document.getElementById(v + "/" + t.split(":")[0]);
                        if (appendTo) appendTo.style.maxWidth = "0" ;
                }
        }
        if(!appendTo) return 
        var new_event;
        if (appendTo.childElementCount < count){
                new_event = drawCalendarEvent( appendTo, el, "block", type, calendar);
        } else {
                const more_button = document.getElementById(`${v}_more`);
                if (more_button) {
                        more_button.remove();
                }
                new_event = drawCalendarEvent( appendTo, el, "none", type, calendar);
                let more = mani.divBegin();
                        mani.id(`${v}_more`);
                        mani.cursor("pointer");
                        mani.width("100%");
                        mani.textAlign("center");
                        mani.color(mani.__colorScheme.special);
                        mani.title(appendTo.childElementCount - count + " more");
                mani.divEnd();
                appendTo.append(more);
                more.onclick = (e) => {
                        let events = [...appendTo.children].slice(0, -1);
                        if (more.textContent != "^") { 
                                for (let i of events) {
                                        i.style.display = "block";
                                        more.innerHTML = "^";
                                } 
                        } else {
                                more.innerHTML = appendTo.childElementCount - (count+1) + " more";
                                for (let i of events) {
                                        i.style.display = "none";
                                } 
                                for (let j = 0; j < count; j++) {
                                        events[j].style.display = "block";
                                } 
                        }
                        /*let events = [...appendTo.children].slice(-1);
                        more.innerHTML = appendTo.childElementCount - (count+1) + " more";
                        for (let i of events) {
                                i.style.display = "none";
                        } 
                        for (let j = 0; j < count; j++) {
                                events[j].style.display = "block";
                        } */
                }
        }
        if (scope != null) {
                new_event.addEventListener('click', async() => {
                        const newScope = new __Scope;
                        newScope.pushObject(el,scope).then(__recreatePropertyEditor); 
                })
        }
}

