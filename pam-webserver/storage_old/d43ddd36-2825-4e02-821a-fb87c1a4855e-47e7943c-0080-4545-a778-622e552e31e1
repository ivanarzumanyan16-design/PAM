        /** 
         * Extending leaflet tileLayer function to work with metax maps
        **/

        mapViewEnd() {
                const map_info = this.__maps[this.__maps.length-1];
                this.id(map_info.id);
                this.divEnd();
                const TileLayerMetax = L.TileLayer.extend({
                        getTileUrl: function (coords) {
                                var data = {
                                        r: L.Browser.retina ? '@2x' : '',
                                        s: this._getSubdomain(coords),
                                        x: coords.x,
                                        y: coords.y,
                                        z: this._getZoomForUrl()
                                };
                                if (this._map && !this._map.options.crs.infinite) {
                                        var invertedY = this._globalTileRange.max.y - coords.y;
                                        if (this.options.tms) {
                                                data['y'] = invertedY;
                                        }
                                        data['-y'] = invertedY;
                                }
                                const url = this._url
                                const layerData = L.Util.extend(data, this.options)
                                if (url[layerData.z] === undefined || url[layerData.z][layerData.x] === undefined || url[layerData.z][layerData.x][layerData.y] === undefined) {
                                        const u = this.options.map_url.replace(/\$\{x\}/g, layerData.x)
                                        .replace(/\$\{y\}/g, layerData.y)
                                        .replace(/\$\{z\}/g, layerData.z);
                                        return u;
                                }
                                if (null != url[layerData.z] && url[layerData.z][layerData.x] && url[layerData.z][layerData.x][layerData.y]) {
                                        return "/db/get?id=" + url[layerData.z][layerData.x][layerData.y];
                                }
                        }
                });
                map_info.map = L.map(map_info.id, { minZoom: map_info.min_zoom, maxZoom: map_info.max_zoom, attributionControl:false}).setView([map_info.lat, map_info.lng], map_info.zoom);
                const layerControl = L.control.layers("","",{position: 'bottomleft'}).addTo(map_info.map);
                for(let i in map_info.tileLayers) {
                        const tl = map_info.tileLayers[i];
                        let l = new TileLayerMetax(tl.basemap, {"map_url":tl.tileLayer});
                        layerControl.addBaseLayer(l, tl.name).addTo(map_info.map);
                        if(i == 0) {
                                l.addTo(map_info.map);
                        }
                }
                map_info.clusterLayer = L.markerClusterGroup();
                map_info.clusterLayer.addTo(map_info.map);
                map_info.markers.forEach(marker => {
                        //marker.addTo(map_info.clusterLayer);
                        map_info.clusterLayer.addLayer(marker);
                })
                return map_info.map
        }

