                alert("Can't save drawing no such collection");
                return
        }
        const drawing = {
                name: "New Drawing",
                type: __drawingTypeUUID,
                uuid: "",
                points: []
        }
        const uuid = await mani.metax.save("{}", "application/json");
        drawing.uuid = uuid;
        coordinates.forEach((c, i) => {
                drawing.points.push({
                        name: String(i+1),
                        location: c.lat + "," + c.lng
