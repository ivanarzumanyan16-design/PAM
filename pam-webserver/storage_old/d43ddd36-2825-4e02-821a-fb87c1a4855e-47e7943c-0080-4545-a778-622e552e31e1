function __pushElement(maniTag, css = "") {
        console.assert(maniTag in __maniTagToHTML, `unexpected maniTag = ${maniTag}`);
        const element = document.createElement(__maniTagToHTML[maniTag]);
        element.name = maniTag;
        if(css) {
                element.className += " " + css;
        }
        const parent = __getStackTop();
        console.assert(parent != null);
        parent.appendChild(element);
        __pushContext(element);
        return element;
}

function __pushElementWithoutClass(maniTag) {
        console.assert(maniTag in __maniTagToHTML, `unexpected maniTag = ${maniTag}`);
        const element = document.createElement(__maniTagToHTML[maniTag]);
        element.name = maniTag;
        const parent = __getStackTop();
        console.assert(parent != null);
        parent.appendChild(element);
        __pushContext(element);
        return element;
}

function __popElement(maniTag) {
        console.assert(__getContext(maniTag));
        __maniObjectStack.splice(-1, 1);
}

