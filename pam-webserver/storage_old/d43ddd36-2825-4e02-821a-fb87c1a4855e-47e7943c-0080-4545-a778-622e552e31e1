let firstPoint = '';
let measuringPolylines = [];

function __mapDistanceMeasureClickHandler(marker, map, mapView) {
        if(firstPoint == "") {
                firstPoint = [marker.lat, marker.lng];
                return
        } 
        const secondPoint = [marker.lat, marker.lng];
        const l = measure(firstPoint[0],
                          secondPoint[0],
                          firstPoint[1],
                          secondPoint[1])
        const d = Math.round(l);
        const distancePolyline = L.polyline(
                [firstPoint, secondPoint],
                {color: 'red'}).addTo(map);
        const p = new L.Popup({autoClose: false, closeOnClick: false, autoPan: false})
        .setContent((d / 1000).toString() + "km")
        distancePolyline.bindPopup(p).openPopup();
        measuringPolylines.push(distancePolyline);
        firstPoint = secondPoint;
}

function __endDistanceMeasurement(map, mapView) {
        mapView.style.cursor =  'grab';
        if(measuringPolylines.length != "") {
                for(const p of measuringPolylines) {
                        p.remove();
                }
        }
        firstPoint = "";
        map.measuring = false;
}

function measure(lat1, lat2, lon1, lon2) { 
        const R = 6371e3; // metres 
        const φ1 = lat1 * Math.PI/180; // φ, λ in radians 
        const φ2 = lat2 * Math.PI/180; 
        const Δφ = (lat2-lat1) * Math.PI/180; 
        const Δλ = (lon2-lon1) * Math.PI/180; 
        const a = Math.sin(Δφ/2) * Math.sin(Δφ/2) + 
              Math.cos(φ1) * Math.cos(φ2) * 
              Math.sin(Δλ/2) * Math.sin(Δλ/2); 
        const c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1-a)); 
        const d = R * c; 
        return d; 
}

function getCookie(cookieName) {
        let cookie = {};
        document.cookie.split(';').forEach(function(el) {
                let [key,value] = el.split('=');
                cookie[key.trim()] = value;
        })
        return cookie[cookieName];
}

function setCookie(cname, cvalue, exdays=30) {
        const d = new Date();
        d.setTime(d.getTime() + (exdays*24*60*60*1000));
        let expires = "expires="+ d.toUTCString();
        document.cookie = cname + "=" + cvalue + ";" + expires + ";path=/;samesite=lax";
}

function wait(ms) {
        return new Promise(resolve => setTimeout(resolve, ms));
}

