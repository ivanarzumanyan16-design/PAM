var dragSrcEl = null;
var remove;
var remove_index;
var mode = "normal";
function __setupEditModeForListItem(listItem, scope) {
        let delay;
        listItem.addEventListener('mousedown', function (e) {
                var _this = this;
                delay = setTimeout(function () {
                        if (mode == "normal") {
                                mode = "edit";
                        }
                        const listItemOnClick = listItem.onclick;
                        listItem.onclick = '';
                        const listItems = [...listItem.parentNode.children].slice(1);
                        for (let i of listItems) {
                                i.setAttribute("draggable", "true");
                                i.style.cursor = "move";
                        }
                        addDnDHandlers(listItems, scope);
                        document.onkeydown = (event) => {
                                if (mode == "edit" ) {
                                        if(event.key === "Escape"){
                                                mode = "normal";
                                                for (let i of listItems) {
                                                        listItem.onclick = listItemOnClick;
                                                        i.setAttribute("draggable", "false");
                                                        i.style.cursor = "unset";
                                                        i.style.opacity = 1;
                                                }
                                        }
                                }
                        }
                }, 1300);
        }, true);
        listItem.addEventListener('mouseup', function (e) {
                clearTimeout(delay);
        });
        listItem.addEventListener('mouseout', function (e) {
                clearTimeout(delay);
        });
        listItem.addEventListener('mousemove', function (e) {
                clearTimeout(delay);
        });
}
function addDnDHandlers(list, scope) {
        for (let listItem of list) { 
                listItem.addEventListener('dragstart', (e) => handleDragStart(e, scope), false);
                listItem.addEventListener('dragover', (e) => handleDragOver(e, scope), false);
                listItem.addEventListener('dragleave', (e) =>  handleDragLeave(e, scope), false);
                listItem.addEventListener('drop', (e) => handleDragDrop(e, scope), false);
        }
}
function handleDragStart(e, scope) {
        var t = e.target; 
        while( t.tagName != "TR") {
                t = t.parentNode;
        }
        t.style.opacity = '0.4';
        dragSrcEl = t;
        e.dataTransfer.effectAllowed = 'move';
        e.dataTransfer.setData('text/html', t.outerHTML);
        let table_rows = t.parentNode.childNodes;
        remove_index = Array.prototype.indexOf.call(table_rows, t) - 1;
        remove = scope.object[scope.tab][remove_index];
}

function handleDragLeave(e, scope) {
        var t = e.target; 
        while( t.tagName != "TR") {
                t = t.parentNode;
        }
        t.style.borderTop = "";
        e.stopPropagation();
}

function handleDragOver(e, scope) {
        var t = e.target; 
        while( t.tagName != "TR") {
                t = t.parentNode;
        }
        t.style.borderTop = "3px solid" + mani.__colorScheme.special;
        e.preventDefault();
        e.dataTransfer.dropEffect = 'move';
        return false;
}

function handleDragDrop(e, scope) {
        var t = e.target; 
        while( t.tagName != "TR" ) {
                t = t.parentNode;
        }
        t.style.borderTop = "";
        t.style.opacity = '1';
        if (dragSrcEl == t) {
                return false;
        }
        dragSrcEl.remove();
        var dropHTML = e.dataTransfer.getData('text/html');
        t.insertAdjacentHTML('beforebegin',dropHTML);
        var dropElem = t;
        scope.object[scope.tab].splice(remove_index, 1);
        var list = [];
        for (let i of t.parentNode.children) {
                if (i.tagName == "TR") {
                        list.push(i);
                }
        }
        let i = Array.prototype.indexOf.call(list, dropElem) - 1;
        scope.object[scope.tab].splice(i, 0, remove);
        mani.updateJSON(scope.object.uuid, scope.object)
        .then(r => {
                __recreatePropertyEditor(scope);
        }).catch(e => {
                console.warn("Failed to apply the change."+
                             "please check the network and retry...");
        });
}

