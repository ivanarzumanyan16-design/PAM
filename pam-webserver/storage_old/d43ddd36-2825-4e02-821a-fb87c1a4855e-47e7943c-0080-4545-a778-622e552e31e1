function calendarNextButtonHandler(obj, c, scope, view){
        let calendar = document.getElementById(`${view}_calendar`)
        calendar.remove();
        if (view == "month") {
                m++
                if(m > 11){
                        m = 0;
                        y ++
                }
                __pushContext(scope.frame.lastChild);
                        drawCalendarMonthView(y, m, obj, c, scope);
                __popContext(scope.frame.lastChild);
                let newDate = new Date(y, m);
                document.getElementById("month").innerHTML = newDate.toLocaleString('default', { month: 'long' }) + " " + y ;
                return
        } 
        if (view == "week" ) d += 7; 
        else if (view == "day") d++;
        let endDate = new Date(y, m+1, 0);
        let end = endDate.getDate();
        if ( d > end ) {
                d = d - end;
                m ++
        }
        if(m > 11){
                m = 0;
                y ++
        }
        __pushContext(scope.frame.lastChild);
                if (view == "week") calendarWeekView(obj, c, scope)
