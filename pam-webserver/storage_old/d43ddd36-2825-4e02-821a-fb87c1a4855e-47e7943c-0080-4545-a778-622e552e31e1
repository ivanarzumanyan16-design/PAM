function __chooserSelectButtonCallback(o, propSpec, pValue, scope) {
        const oldValue = o[propSpec.id]
        o[propSpec.id] = pValue.uuid;
        if ("uuid" in o) {
                mani.updateJSON(o.uuid, o, scope.notify)
                .then(r => {
                        mani.notifyPropertyChange(scope.notify, o.uuid, propSpec.id, oldValue)
                        __addInSymmetricElement(o, pValue.uuid, propSpec, scope);
                        __propertyEditorBackButtonHandler(scope);
                })
        } else { 
                console.assert("uuid" in scope.object);
                mani.updateJSON(scope.object.uuid, scope.object)
                .then(r => {
                        mani.notifyPropertyChange(scope.notify, scope.object.uuid, propSpec.id, oldValue)
                        __propertyEditorBackButtonHandler(scope);
                })
        }
}

