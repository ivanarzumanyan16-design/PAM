        audioPlayerSource(src) {
                let play_button_src ="1efe5e17-a690-4be6-8577-2e7c809bacb2";
                let pause_button_src ="363b18ad-9563-483c-8168-e571538e062d";
                var isPlaying = false;
                this.display("flex");
                this.alignItems("center");
                this.width("400px");
                const audio = this.audioBegin();
                        this.display("none");
                        this.audioSource(src);
                this.audioEnd();
                const play_button = this.imageBegin();
                        this.width("40px");
                        this.imageSource(play_button_src);
                this.imageEnd();
                const slider = this.sliderBegin();
                        this.flex("1");
                        this.margin(" 0 2%");
                this.sliderEnd();
                slider.min = 0;
                slider.value = 0;
                const time = this.spanBegin();
                this.spanEnd();
                var curtime;
                var d;
                audio.onloadedmetadata = () => {
                        slider.max = Math.floor(audio.duration);
                        curtime = Math.floor(audio.currentTime);
                        let dmins = ('0' + Math.floor(audio.duration / 60)).slice(-2);
                        let dsecs = ('0' + Math.floor(audio.duration % 60)).slice(-2);
                        d = dmins + ":" + dsecs;
                        time.textContent = "00:00 / " + d; 
                }
                slider.oninput = () => {
                        audio.currentTime = slider.value;
                        curtime = audio.currentTime;
                        let mins = ('0' + Math.floor(curtime / 60)).slice(-2);
                        let secs = ('0' + Math.floor(curtime % 60)).slice(-2);
                        let ad = time.textContent.split("/")[1]; 
                        time.textContent = mins +":"+ secs + " / " + ad; 
                }
                play_button.onclick = async () => {
                        if (!isPlaying) {
                                play_button.src = "/db/get?id=" + pause_button_src;
                                audio.play();
                                isPlaying = true;
                                while ( curtime <= Math.floor(audio.duration)) {
                                        if(curtime == Math.floor(audio.duration)) {
                                                play_button.src = "/db/get?id=" + play_button_src;
                                        }
                                        if(!isPlaying) {
                                                break;
                                        }
                                        slider.value = curtime;
                                        let mins = ('0' + Math.floor(curtime / 60)).slice(-2);
                                        let secs = ('0' + Math.floor(curtime % 60)).slice(-2);
                                        time.textContent = mins +":"+ secs + " / " + d; 
                                        curtime = audio.currentTime;
                                        await wait(1000);
                                }
                        } else {
                                play_button.src = "/db/get?id="+play_button_src;
                                isPlaying = false;
                                audio.pause();
                        }
                }
        
        
        }
        
