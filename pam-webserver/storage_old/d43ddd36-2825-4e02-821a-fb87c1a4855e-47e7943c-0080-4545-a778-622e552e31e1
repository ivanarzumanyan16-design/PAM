        getCurrentLocale() {
                return this.__currentLocale?.code;
        }
                
        getBaseLocale() {
                return this.__currentLocale?.base;
        }
        
        setCurrentLocale(l) {
                setCookie("mani_locale", JSON.stringify(l), 30);
                this.__currentLocale = l;
        }
        
        getLiteralValue(o, p) {
                return typeof(o[p]) === "object" ? 
                        o[p][this.getCurrentLocale()] ||
                        this.getValueInBaseLocale(o, p) || "" : o[p] || "";
        }
                
        getValueInBaseLocale(o, p) {
                console.assert(typeof o[p] === "object");
                let base = this.getBaseLocale();
                while (base) {
                        if (o[p][base.code] !== undefined) {
                                return o[p][base.code];
                        }
                        base = base.base;
                }
        }
        
        setLiteralValue(o, p, v) {
                if (typeof (o[p]) !== "object") {
                        o[p] = {};
                }
                o[p][this.getCurrentLocale()] = v;
        }
        
        hasValueInCurrentLocale(o, p) {
                if (p.enable_internalization !== __trueUUID) {
                        return null
                }
                if (this.metax.isValidUUID(o[p.id])) {
                        return null
                } else if (typeof o[p.id] !== "object") {
                        return false
                } else if (!o[p.id][this.getCurrentLocale()]) {
                        return false
                }
                return true
        }
        
        async wrap(uuid) {
                console.assert(this.metax.isValidUUID(uuid));
                const o = await this.getJSON(uuid)
                        .catch(e => { 
                                throw Error(`fetch(${uuid}) resulted in error:\n ${e}`);
                        })
                return o
        }
        
        getLiteralProperty(o, p) {
                return o[p] || "";
        }
        
        setLiteralProperty(o, p, v) {
                o[p] = v;
        }
        
        async getProperty(o, p) {
                if (!this.metax.isValidUUID(this.getLiteralProperty(o, "type"))) {
                        return this.getLiteralValue(o, p);
                }
                const type = await this.wrap(this.getLiteralProperty(o, "type"));
                let propSpec;
                if (o.type === __versionControlItemTypeUUID && p === "value") {
                        propSpec = o.propspec;
                } else {
                        propSpec = this.getPropSpec(type, p);
                }
                if (!propSpec) {
                        return this.getLiteralValue(o, p);
                }
                let value = o;
                if (__isVersionControlEnabled(propSpec)) {
                        if(this.metax.isValidUUID(mani.getLiteralProperty(value, p))) {
                                const object = await this.wrap(mani.getLiteralProperty(value, p));
                                if (this.getLiteralProperty(object, "type") === __versionControlItemTypeUUID) {
                                        value = object;
                                        p = "value";
                                } 
                        } 
                }
                const value_type = propSpec.value_type && propSpec.value_type[0] !== "$" ?
                                    await this.wrap(this.getLiteralProperty(propSpec, "value_type")) : undefined;
                if (!value_type || __isLiteralType(value_type)) {
                        if (__isInternalizationEnabled(propSpec)) {
                                value = this.getLiteralValue(value, p);
                        } else {
                                value = this.getLiteralProperty(value, p);
                        }
                } else {
                        const uuid = this.getLiteralProperty(value, p);
                        if (!uuid) return ""
                        value = await this.wrap(uuid);
                }
                return value || "";
        }
        
        async setProperty(o, p, v, eot) {
                const rootObject = o;
                if (!this.metax.isValidUUID(this.getLiteralProperty(o, "type")) && !eot) {
                        return this.setLiteralProperty(o, p, v);
                }
                const type = eot || await this.wrap(this.getLiteralProperty(o, "type"));
                const propSpec = this.getPropSpec(type, p);
                if (__isVersionControlEnabled(propSpec)) {
                        if(this.metax.isValidUUID(this.getLiteralProperty(o, p))) {
                                const object = await this.wrap(this.getLiteralProperty(o, p));
                                if (this.getLiteralProperty(object, "type") === __versionControlItemTypeUUID) {
                                        o = object;
                                }
                        } 
                        if (this.getLiteralProperty(o, "type") !== __versionControlItemTypeUUID) {
                                const version_control_item = await this.__setNewVersionControlPropertyValue(o, p);
                                o = version_control_item;
                        }
                        p = "value";
                } 
                if (__isInternalizationEnabled(propSpec)) {
                        this.setLiteralValue(o, p, v);
                } else {
                        this.setLiteralProperty(o, p, v);
                }
                if (__isVersionControlEnabled(propSpec)) {
                        await this.metax.update(this.getLiteralProperty(o, "uuid"), JSON.stringify(o));
                }
                if (__isAutomaticVersionControlEnabled(propSpec)) {
                        await __commitPropertyCurrentVersion(rootObject, propSpec)
                }
        }
        
        getPropSpec(t, p) {
                const properties = this.getCollection(t, "properties");
                return properties.find(propSpec => propSpec.id === p);
        }
        
        getCollection(o, c) {
                console.assert(c in o);
                console.assert(o[c]);
                return o[c];
        }
        
        async getCollectionItem(o, t, c, i) {
                const cSpec = this.__getCollectionSpec(t, c);
                if (cSpec.kind === __ownedKindUUID || cSpec.kind === __compositionKindUUID) {
                        return await this.__getOwnedCollectionItem(o, c, i); 
                } else if(cSpec.kind === __embeddedKindUUID) {
                        return this.__getEmbeddedCollectionItem(o, c, i); 
                }
        }
        
        async deleteCollectionItem(o, c, i) {
                console.assert(o[c].length > 0);
                console.assert(o[c][i]);
                console.assert(typeof(o[c][i]) == "object");
                o[c].splice(i, 1);
                await this.metax.update(o.uuid, JSON.stringify(o));
        }
        
        async createCollectionItem(o, t, c, i=0) {
                const cSpec = this.__getCollectionSpec(t, c);
                const elt = await this.wrap(cSpec.element_type);
                let newObject;
                if (cSpec.kind === __ownedKindUUID) {
                        newObject = await this.__createNewOwnedCollectionElement(o, c, elt, i);
                } else if (cSpec.kind === __embeddedKindUUID) {
                        newObject = this.__createNewEmbeddedCollectionElement(o, c, elt, i);
                }
                await this.metax.update(o.uuid, JSON.stringify(o));
                return newObject;
        }
        
        async addCompositionCollectionItem(o, t, c, v, i=0) {
                const cSpec = this.__getCollectionSpec(t, c);
                console.assert(cSpec.kind === __compositionKindUUID);
                const item = await this.wrap(v);
                if (item.type !== cSpec.element_type) {
                        return 
                }
                this.addCollectionElement(o, c, v, i)
                await this.metax.update(o.uuid, JSON.stringify(o));
                
        }
        
        addCollectionElement(o, c, v, i=0) {
                const collection = this.getCollection(o, c);
                if (!i) {
                        collection.push(v);
                } else {
                        collection.splice(i, 0, v);
                }
        
        }
        
        async __createNewOwnedCollectionElement(o, c, elt, i) {
                const newObject = __createNewVostanObject(elt);
                const uuid = await this.metax.save(JSON.stringify(newObject));
                newObject.uuid = uuid;
                this.addCollectionElement(o, c, newObject.uuid, i)
                await this.metax.update(uuid, JSON.stringify(newObject));
                return newObject
        }
        
        __createNewEmbeddedCollectionElement(o, c, elt, i) {
                const newObject = __createNewEmbeddedObject(elt);
                this.addCollectionElement(o, c, newObject, i)
                return newObject
        }
        
        __getCollectionSpec(tSpec, id) {
                return tSpec.collections.find(c => c.id === id);
        }
        
        async __getOwnedCollectionItem(o, c, i) {
                console.assert(o[c].length > 0);
                console.assert(o[c][i]);
                console.assert(this.metax.isValidUUID(o[c][i]));
                const el = await this.wrap(o[c][i]);
                return el;
        }
        
        __getEmbeddedCollectionItem(o, c, i) {
                console.assert(o[c].length > 0);
                console.assert(o[c][i]);
                const el = o[c][i];
                return el;
        }
        
        async __setNewVersionControlPropertyValue(o, p) {
                const version_control_item = {
                        type: __versionControlItemTypeUUID,
                        value: this.getLiteralProperty(o, p),
                        name: `${this.getLiteralValue(translationTable, "new")} ${this.getLiteralValue(translationTable, "version")}`,
                }
                const uuid = await this.metax.save(JSON.stringify(version_control_item));
                version_control_item.uuid = uuid;
                this.setLiteralProperty(o, p, uuid);
                await this.metax.update(this.getLiteralProperty(o, "uuid"), JSON.stringify(o));
                return version_control_item
        }
        
