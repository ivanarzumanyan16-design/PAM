                        this.cursor("pointer");
                        this.title(`Lat: ${mapinfo.map.getCenter().lat.toFixed(6)}, Lng: ${mapinfo.map.getCenter().lng.toFixed(6)}, Zoom: ${mapinfo.map.getZoom()}`);
                this.paragraphEnd();
                cc.onclick = () => {
                        navigator.clipboard.writeText(`${mapinfo.map.getCenter().lat.toFixed(6)},${mapinfo.map.getCenter().lng.toFixed(6)}`);
                        cc.textContent = "Copied to clipboard"
                        setTimeout(() => {
                                cc.textContent = `Lat: ${mapinfo.map.getCenter().lat.toFixed(6)}, Lng: ${mapinfo.map.getCenter().lng.toFixed(6)}, Zoom: ${mapinfo.map.getZoom()}`;
                        }, 500)
                }
                mapinfo.map.on('zoom', function() {
                        cc.textContent = `Lat: ${mapinfo.map.getCenter().lat.toFixed(6)}, Lng: ${mapinfo.map.getCenter().lng.toFixed(6)}, Zoom: ${mapinfo.map.getZoom()}`;
                });
                mapinfo.map.on('moveend', function(e) {
                        cc.textContent = `Lat: ${mapinfo.map.getCenter().lat.toFixed(6)}, Lng: ${mapinfo.map.getCenter().lng.toFixed(6)}, Zoom: ${mapinfo.map.getZoom()}`;
                });
                mapContainer.append(cc);
        }
                
        __drawMapDrawingButtons(mapinfo, edit, onDrawingCreateCallBack) {
                const drawControl = new L.Control.Draw({
                        draw: {
                                 polyline: true,
                                 polygon: false,
                                 circle: false,
                                 marker: false,
                                 rectangle: false,
                                 circlemarker: false,
                        }
                });
                mapinfo.map.addControl(drawControl);
                const drawControlContainer = drawControl.getContainer(); 
                if (!edit) {
                        drawControlContainer.style.opacity = 0.5;
                        drawControlContainer.style.pointerEvents = 'none';
                        const disabledButtons = drawControlContainer.querySelectorAll('.leaflet-draw-draw-polyline, .leaflet-draw-draw-polygon')
                        for (const button of disabledButtons) {
                                button.addEventListener('click', (event) => event.preventDefault());
                        }
                }
                mapinfo.map.on(L.Draw.Event.CREATED, (event) => {
                        const layer = event.layer;
                        mapinfo.drawingsLayer.addLayer(layer);
                        const coordinates = layer.getLatLngs();
                        onDrawingCreateCallBack(coordinates, mapinfo.map);
                });
        }
        
        __drawEditDrawingButton(mapinfo, mapContainer) {
                const editButton = mani.buttonBegin();
                        mani.title("Edit");//get i18ned value
                        mani.fromRight("1%");
                        mani.zIndex("1010");
                        mani.fromTop("12%");
                        mani.backgroundColor("white");
                        mani.color("black");
                        mani.border("1px solid rgb(135,135,135)");
                        mani.borderRadius("5px");
                        mani.position("absolute");
                        mani.width("40px");
                        mani.height("34px");
                        mani.textAlign("center");
                        mani.fontSize("smaller");
                        mani.padding("0");
                mani.buttonEnd();
                editButton.onclick = () => {
                        if (mapinfo.editing === true) {
                                mapinfo.editing = false;
                                editButton.textContent = "Edit";
                                this.__saveEditedDrawing(mapinfo);
                                this.__disableDrawingsEditing(mapinfo);
                        } else {
                                mapinfo.editing = true;
                                editButton.textContent = "Save";
                        }
                }
                mapContainer.append(editButton);
        }
                
        async __saveEditedDrawing(mapinfo) {
                const polyline = mapinfo.editedDrawing;
                const drawing = await this.getJSON(polyline._leaflet_id);
                drawing.points = [];
                const coordinates = polyline.getLatLngs();
                coordinates.forEach((c, i) => {
                        drawing.points.push({
                                name: String(i+1),
                                location: c.lat + "," + c.lng
                        })
                })
                await this.updateJSON(drawing.uuid, drawing);
        }
                
        mapViewTools(map, edit, onDrawingCreateCallBack) {
                const mapinfo = this.__maps[this.__maps.length-1];
                const tools = this.divBegin();
                        this.zIndex("1010");
                        this.fromRight("1%");
                        this.fromTop("1%");
                        this.position("absolute");
                        this.display("flex");
                        this.flexDirection("column");
                        this.gap("5px");
                        this.__drawMapFullScreenButton(map);
                        this.__drawDistanceMeasurementButton(mapinfo, map);
                this.divEnd();
                map.append(tools);
                this.__drawMapCenterCoordinates(mapinfo, map);
                mapinfo.drawingsLayer = new L.FeatureGroup();
                mapinfo.map.addLayer(mapinfo.drawingsLayer);
                this.__drawMapDrawingButtons(mapinfo, edit, onDrawingCreateCallBack);
                if (edit) {
                        this.__drawEditDrawingButton(mapinfo, map);
                }
        }
        __disableDrawingsEditing(mapinfo) {
                mapinfo.drawingsLayer.eachLayer((layer) => {
                        layer.editing.disable();
                });
        }
                
        mapViewDrawing(drawing) {
                const mapinfo = this.__maps[this.__maps.length - 1];
                const coordinates = drawing.points.map(point => point.location.split(","));
                const polyline = L.polyline(coordinates, { editable: false });
                polyline._leaflet_id = drawing.uuid;
                polyline.bindTooltip(mani.getLiteralValue(drawing, "name"));
                polyline.on("click", () => {
                        if (!mapinfo.editing) return
                        this.__disableDrawingsEditing(mapinfo);
                        polyline.editing.enable();
                        mapinfo.editedDrawing = polyline;
                })
                mapinfo.drawingsLayer.addLayer(polyline);
        }
        
