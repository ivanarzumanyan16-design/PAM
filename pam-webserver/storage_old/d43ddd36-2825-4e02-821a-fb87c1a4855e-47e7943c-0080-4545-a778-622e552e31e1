function startMpegTsStream(streamUUID, element) {
        var mediaDataSource = {
                type: 'mpegts',
                isLive: true,
                hasAudio: false,
                hasVideo: true,
                url: streamUUID
        };
        if (typeof player !== "undefined") {
                if (player != null) {
                        player.unload();
                        player.detachMediaElement();
                        player.destroy();
                        player = null;
                }
        }
        player = mpegts.createPlayer(mediaDataSource, {
                enableWorker: true,
                enableStashBuffer: false,
                isLive: true,
		lazyLoad: false,
                liveBufferLatencyChasing: true,
                liveBufferLatencyMaxLatency: 1,
                liveBufferLatencyMinLatency: 0.2,
                autoCleanupSourceBuffer: true
        });
        player.attachMediaElement(element);
        player.load();
}

async function saveRecordedAudio(o, id, rec, e, audio, scope) {
        const audioChuncks = []
        audioChuncks.push(e.data);
        if (rec.state == "inactive"){
                let blob = new Blob(audioChuncks,{type:'audio/mp3'});
                let formdata = new FormData();
                formdata.append(1, blob);
                const uuid = await mani.metax.saveData(formdata);
                audio.src = "/db/get?id=" + uuid;
                o[id] = uuid;
                mani.updateJSON(o.uuid, o)
                audio.style.display = "block";
                audio.controls=true;
                audio.autoplay=false;
                audio.preload="none";
                audioChuncks = []
        }
}

