function saveExternalTextBody(el, v, currentType, extText, uuidbox, o, propspec) {
        if(el.body) {
                console.assert(mani.metax.isValidUUID(el.body));
                mani.metax.update(el.body, v, currentType)
                        .then(async r => {
                                if(json_editor) return
