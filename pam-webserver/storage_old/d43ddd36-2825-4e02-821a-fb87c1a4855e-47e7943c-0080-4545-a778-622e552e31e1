async function __createObjectPropertyEntryField(o, propSpec, valueType, scope, isTableView) {
        if(!__hasPropertyValue(o, propSpec.id)) {
                __setDefaultSettingsForObjectField(o, propSpec, scope, isTableView); 
                return o;
        }
        const readOnly = __isReadOnlyProperty(propSpec);
        console.assert(__hasProperty(o, propSpec.id));
        //console.assert(propSpec.id in o);
        const uuid = o[propSpec.id];
        console.assert(__isValidTypeReference(uuid));
        const inputRow = mani.rowBegin();
                const objectB = mani.buttonBegin();
                mani.buttonEnd();
                const selectorB = mani.buttonBegin();
                mani.buttonEnd();
                const clearB = mani.buttonBegin();
                mani.buttonEnd();
                __createEmptyObjectField(o, propSpec, objectB, selectorB, clearB, scope);
        mani.rowEnd();
        const obj = !mani.metax.isValidUUID(uuid) ? uuid : await mani.getJSON(uuid).catch(e => {
                console.error(`could not retreive ${uuid} from metax: ${e}`)
                __pushContext(inputRow);
                        __createObjectPropertyEntryFieldWithError(e,o,propSpec,scope);
                __popContext(inputRow);
        });
        console.assert(obj.type === propSpec.value_type ||
                       propSpec.value_type == __uuidTypeUUID ||
                       propSpec.value_type == __typeUUID && obj[0] === "$");
        __pushContext(inputRow);
