function getKeywordObject(string, object, embObject) {
        const parts = string.split(".");
        let o;
        if (keyword_map[parts[0]] === "object") {
                o = object
        } else if (keyword_map[parts[0]] === "embeddedObject") {
                o = embObject
        }
        if (keyword_map[parts[0]] === undefined || !o ) return false
        for (let str of parts.slice(1)) {
                if (o[str] === undefined)  {
                        return false
                }
                o = o[str];
        }
        return o.uuid !== undefined ? o.uuid : o
}

