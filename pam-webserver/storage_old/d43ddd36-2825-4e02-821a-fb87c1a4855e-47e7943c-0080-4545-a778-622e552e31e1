                const element = __getStackTop();
                console.assert( -1 != 
                        ["mani-button", "mani-list-item", "mani-edit-string",
                         "mani-edit-number", "mani-edit-date", "mani-edit-icon",
                         "mani-edit-boolean", "mani-label", "mani-edit-text", "mani-combobox",
                         "mani-combobox-item", "mani-table-row"].indexOf(element.name) );
                element.disabled = d;
                element.style.opacity = d ? 0.3 : 1;
        }
        
