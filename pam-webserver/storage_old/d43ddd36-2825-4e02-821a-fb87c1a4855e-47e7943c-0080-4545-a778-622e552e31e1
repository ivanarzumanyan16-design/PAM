async function __commitPropertyCurrentVersion(o, propSpec) {
        const isExternalText = propSpec.value_type === "3e76b8ff-9063-4052-b67a-ecd43302d269";
        const date = new Date();
        if (!mani.metax.isValidUUID(o[propSpec.id])) {
                await mani.setProperty(o, propSpec.id, mani.getLiteralValue(o, propSpec.id));
        }
        let vc_item = await mani.wrap(o[propSpec.id]);
        if (vc_item.type !== __versionControlItemTypeUUID) { 
                await mani.setProperty(o, propSpec.id, mani.getLiteralValue(o, propSpec.id));
                vc_item = await mani.wrap(o[propSpec.id]);
        }
        if (!await __isPropertyCurrentVersionValueChanged(vc_item, isExternalText)) {
                return null
        }
        const previous_vc_item = JSON.parse(JSON.stringify(vc_item));
        const previous_version_uuid = await mani.metax.save(JSON.stringify(previous_vc_item));
        previous_vc_item.date = `${date.getFullYear()}-${("0" + (date.getMonth()+1)).slice(-2)}-${("0" + date.getDate()).slice(-2)}`
        previous_vc_item.uuid = previous_version_uuid;
        previous_vc_item.object = o.uuid;
        previous_vc_item.propspec = propSpec;
        //const author = await mani.metax.getUserID();
        const author = mani.account;
        if (mani.metax.isValidUUID(author)) {
                previous_vc_item.author = author;
        }
        if (propSpec.enable_version_tracking === __versionControlHistoryOnlyKindUUID ||
            propSpec.enable_version_tracking === __versionControlAutomaticKindUUID) {
                previous_vc_item.name = `${previous_vc_item.date} ${("0" + date.getHours()).slice(-2)}:${("0" + date.getMinutes()).slice(-2)}`;
        }
        if (isExternalText) {
                await __commitExternalTextPropertyValue(previous_vc_item);
        }
        await mani.updateJSON(previous_vc_item.uuid, previous_vc_item);
        vc_item.previous = previous_version_uuid;
        await mani.updateJSON(vc_item.uuid, vc_item);
        return previous_vc_item
}

async function __commitExternalTextPropertyValue(vc_item) {
        const external_text = await mani.wrap(vc_item.value);
        const {mime} = external_text;
        console.assert("body" in external_text);
        console.assert(external_text.body);
        console.assert(mani.metax.isValidUUID(external_text.body));
        const external_text_body = await mani.metax.get(external_text.body).then(r => r.text());
        const new_external_text_body_uuid = await mani.metax.save(external_text_body, mime);
        external_text.body = new_external_text_body_uuid;
        const new_external_text_uuid = await mani.metax.save(JSON.stringify(external_text));
        external_text.uuid = new_external_text_uuid;
        await mani.updateJSON(external_text.uuid, external_text);
        vc_item.value = external_text.uuid;
}

async function __revertExternalTextPropertyValue(object, id, ext_text) {
        const vc_item = await mani.wrap(object[id]);
        const current_ext_text = await mani.wrap(vc_item.value);
        const ext_text_body = await mani.metax.get(ext_text.body).then(r => r.text());
        await mani.metax.update(current_ext_text.body, ext_text_body);
        if (current_ext_text.mime !== ext_text.mime) {
                current_ext_text.mime = ext_text.mime;
                await mani.updateJSON(current_ext_text.uuid, current_ext_text);
        }
}

async function __isPropertyCurrentVersionValueChanged(item, externalText) {
        if (!item.previous) {
                return true
        }
        const previous = await mani.wrap(item.previous);
        if ( previous.value === item.value ) return false
        if ( JSON.stringify(previous.value) === JSON.stringify(item.value) ) return false
        if (!externalText) return true
        const currentValue = await mani.wrap(item.value);
        const previousValue = await mani.wrap(previous.value);
        if (currentValue.mime !== previousValue.mime) return true
        const currentBody = await mani.metax.get(currentValue.body).then(r => r.text());
        const previousBody = await mani.metax.get(previousValue.body).then(r => r.text());
        if (previousBody === currentBody) return false
        return true
}

