async function __drawMarkersInMapView(c, id, scope, map) {
        for (let i of scope.object[c.id]) {
                let el = c.kind == __embeddedKindUUID ? i : await mani.getJSON(i);
                if (!el[id]) continue
                const marker_icon = el.icon ;
                let marker = mani.mapViewMarker(el[id], marker_icon);
                marker.on("click", function() {
                        const mapinfo = mani.getLastMapInfo();
                        if (mapinfo.measuring === true) {
                                const m = {
                                        "lat": el[id].split(",")[0],
                                        "lng": el[id].split(",")[1]
                                }
                                __mapDistanceMeasureClickHandler(m, mapinfo.map, map)
                                return
                        }
                        const newScope = new __Scope;
                        if (c.kind == __embeddedKindUUID) {
                                newScope.pushEmbeddedObject(el,c,scope)
                                        .then(__recreatePropertyEditor); 
                        } else {
                                newScope.pushObject(el,scope)
                                        .then(__recreatePropertyEditor); 
                        }
                });
        }
}
