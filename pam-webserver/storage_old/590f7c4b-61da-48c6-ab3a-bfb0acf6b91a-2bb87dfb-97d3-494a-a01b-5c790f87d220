function draw_date(is_first, is_new, message, new_msg, not_saved) {
        const month_names = [
                "Հունուար", "Փետրուար", "Մարտ", "Ապրիլ", "Մայիս", "Հունիս",
                "Հուլիս", "Աւգոստոս", "Սեպտեմբեր", "Հոկտեմբեր", "Նոյեմբեր", "Դեկտեմբեր"
        ];

        if(!message) {
                return
        }

        const parsed_date = new Date(message.date);

        const year = parsed_date.getFullYear();
        const month = parsed_date.getMonth();
        const day = parsed_date.getDate();

        const msg_date_obj =  {
                year,
                month,
                day
        }

        message_date_array.unshift(msg_date_obj)
        if (is_first === true) {
                const formatted_date = `${year} ${month_names[month]}ի ${day}`;
                let date_div = document.createElement('div');
                let date_string = document.createElement('p');

                date_div.className = "date_div";
                date_string.className = "date_string";

                date_string.textContent = formatted_date;

                date_div.appendChild(date_string);
                chat_body.insertBefore(date_div, chat_body.firstChild);
                date_array.unshift(parsed_date);
                return
        } else if(message_date_array.length > 1){
                let date = null;

                if(not_saved) {
                        let is_equal = compare_dates(message_date_array[0], message_date_array[1])

                        if(is_equal.compare === true) {
                                new_msg = true
                        } else {
                                new_msg = false
                        }
                }

                if(!new_msg) {
                        date = compare_dates(message_date_array[0], message_date_array[1], is_new) 
                } else {
                        date = compare_dates(message_date_array[0], message_date_array[message_date_array.length - 1], is_new) 
                }

                if(message_date_array.length === 20) {
                        message_date_array.reverse();
                }

                if(!is_new && date.compare === true){
                        const formatted_date = `${date.higher.year} ${month_names[date.higher.month]}ի ${date.higher.day}`;
                        let date_div = document.createElement('div');
                        let date_string = document.createElement('p');

                        date_div.className = "date_div";
                        date_string.className = "date_string";

                        date_string.textContent = formatted_date;

                        date_div.appendChild(date_string);
                        chat_body.insertBefore(date_div, document.getElementById(message.uuid));
                } else if(is_new && date.compare === true) {
                        const formatted_date = `${date.higher.year} ${month_names[date.higher.month]}ի ${date.higher.day}`;
                        let date_div = document.createElement('div');
                        let date_string = document.createElement('p');

                        date_div.className = "date_div";
                        date_string.className = "date_string";

                        date_string.textContent = formatted_date;

                        date_div.appendChild(date_string);
                        chat_body.insertBefore(date_div, document.getElementById(message.uuid).nextSibling);
                }
        }
}

function compare_dates(date1, date2, is_new) {
        if (date1 === undefined || date2 === undefined) {
                return { compare: false };
        }

        if (date1.year !== date2.year) {
                if(!is_new) {
                        return {
                                compare: date1.year > date2.year,
                                higher: date1
                        };
                } else {
                        return {
                                compare: date1.year < date2.year,
                                higher: date2
                        };
                }
        }

        if (date1.month !== date2.month) {
                if(!is_new) {
                        return {
                                compare: date1.month > date2.month,
                                higher: date1
                        };
                } else {
                        return {
                                compare: date1.month < date2.month,
                                higher: date2
                        };
                }
        }

        if (date1.day !== date2.day) {
                if(!is_new) {
                        return {
                                compare: date1.day > date2.day,
                                higher: date1
                        };
                } else {
                        return {
                                compare: date1.day < date2.day,
                                higher: date2
                        };
                }
        }

        return { compare: false };
}

