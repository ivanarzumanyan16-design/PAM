                        chat_body.appendChild(loading_image);

                        let previous_scroll_height = chat_body.scrollHeight;
                        const previous_messages = await fetch_messages(chat.uuid, message_uuids_array, 20);
                        if (previous_messages.length === 0) {
                                loading_image.remove();
                                return;
                        }

                        const previous_message_promises = previous_messages.map(async (message) => {
                                const message_data = await getJSON(message);
                                const is_message_seen = message_data.seens.includes(my_user_account);
                                if (!is_message_seen) {
                                        message_data.seens.push(my_user_account);
                                        await updateJSON(message, JSON.stringify(message_data));
                                }
                                return message_data;
                        });

                        const previous_message_array = await Promise.all(previous_message_promises);
                        previous_message_array.reverse(); 

                        await Promise.all(previous_message_array.map(async (message_data) => {
                                await draw_messages(message_data, true, chat_uuid, false);
                                await handle_message_status(message_data);
                        }));

                        const new_scroll_height = chat_body.scrollHeight;
                        const scroll_delta = new_scroll_height - previous_scroll_height;
                        chat_body.scrollTop += scroll_delta;

