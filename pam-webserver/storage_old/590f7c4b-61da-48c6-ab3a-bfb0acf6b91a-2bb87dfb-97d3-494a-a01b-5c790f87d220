async function get_chats() {
        history.pushState({ title: 'Messenger Interface', visibility: 'show_chats' }, 'Show Div', '/db/get?id=b41414a4-e503-4df2-b104-1a831b51f6ba-15ebcfce-0817-4733-bb47-4280be75a648');
        try {
                const messenger = await getJSON(messenger_uuid);
                const author_data = await metax.getUserID();

                const user_promises = messenger.users.map(async user_id => {
                        const user = await getJSON(user_id);
                        if (user.mani_account === author_data) {
                                my_user_account = user.uuid;
                                await get_name(my_user_account);
                                if(is_android) {
                                        AndroidInterface.sendData(my_user_account);
                                }

                                for (const chat of user.chats) {
                                        const chat_data = await getJSON(chat);
                                        const msg_data = chat_data.messages.length 
                                        ? await getJSON(chat_data.messages.at(-1)) 
                                        : { date: "" };

                                        user_chats.push({ chat: chat_data, message: msg_data });
                                }

                                user_chats.sort((a, b) => {
                                        if (a.message.date === "") return -1;
                                        if (b.message.date === "") return 1;

                                        const date_a = new Date(a.message.date);
                                        const date_b = new Date(b.message.date);

                                        return date_a - date_b;
                                });


                                for (const user_data of user_chats) {
                                        create_chat(user_data.chat);

                                        const is_listened = register_listener_uuids.includes(user_data.chat.uuid);
                                        if(!is_listened) {
                                                register_listener_uuids.push(user_data.chat.uuid)
                                                metax.registerListener(user_data.chat.uuid, async function listener() {
                                                        await get_new_message(user_data.chat.uuid);
                                                });
                                        }
                                }

                                messenger_chat_body.style.pointerEvents = "auto";
                        }
                });

                await Promise.all(user_promises);
        } catch (e) {
                console.error(e);
        }
}

