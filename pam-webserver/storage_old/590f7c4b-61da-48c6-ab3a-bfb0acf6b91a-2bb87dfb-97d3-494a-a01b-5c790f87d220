function update_audio_progress(audio, duration_id, progress_id, button_id, duration) {
        try {
                const duration_display = document.getElementById(duration_id);
                const progress_bar = document.getElementById(progress_id);
                const remaining_time = audio.duration - audio.currentTime;
                const remaining_minutes = Math.floor(remaining_time / 60);
                const remaining_seconds = Math.floor(remaining_time % 60);
                const display_time = remaining_minutes + ":" + (remaining_seconds < 10 ? '0' : '') + remaining_seconds;

                duration_display.textContent = display_time;

                const progress = ((audio.duration - remaining_time) / audio.duration) * 100;
                progress_bar.style.width = progress + "%";
                if(progress == 100) {
                        document.getElementById(button_id).src = "/db/get?id=1e7a7179-0784-4d85-a662-fb10bd58a877-bc5dd792-e712-49b8-9b1e-b19f58c0f3df"
                }
        } catch(e) {
                console.error(e)
        }
}


