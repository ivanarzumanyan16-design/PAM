const pinch_zoom = (img, divImg) => {
        try {
                var initial_distance = 0;
                var initial_width = img.width;
                var initial_height = img.height;
                var start_x = 0, start_y = 0;
                var initial_left = 0, initial_top = 0;
                var is_moving = false;

                function getDistance(touch1, touch2) {
                        var dx = touch2.clientX - touch1.clientX;
                        var dy = touch2.clientY - touch1.clientY;
                        return Math.sqrt(dx * dx + dy * dy);
                }

                img.addEventListener('touchstart', function (e) {
                        const close_divs = document.getElementsByClassName("close_image_div");
                        close_divs[0].style.display = "none";
                        if (e.touches.length === 2) {
                                initial_distance = getDistance(e.touches[0], e.touches[1]);
                                initial_width = img.width;
                                initial_height = img.height;
                                is_moving = false;
                        } else if (e.touches.length === 1) {
                                start_x = e.touches[0].clientX;
                                start_y = e.touches[0].clientY;
                                initial_left = img.offsetLeft;
                                initial_top = img.offsetTop;
                                is_moving = true;
                        }
                });

                img.addEventListener('touchmove', function (e) {
                        const close_divs = document.getElementsByClassName("close_image_div");
                        close_divs[0].style.display = "none";
                        if (e.touches.length === 2) {
                                e.preventDefault(); 
                                var new_distance = getDistance(e.touches[0], e.touches[1]);
                                var scale = new_distance / initial_distance;
                                var new_width = initial_width * scale;
                                var new_height = initial_height * scale;

                                if (new_width >= divImg.clientWidth && new_height >= divImg.clientHeight) {
                                        img.style.width = new_width + 'px';
                                        img.style.height = new_height + 'px';
                                }
                        } else if (e.touches.length === 1 && is_moving) {
                                e.preventDefault();
                                var delta_x = e.touches[0].clientX - start_x;
                                var delta_y = e.touches[0].clientY - start_y;
                                var new_left = initial_left + delta_x;
                                var new_top = initial_top + delta_y;

                                var right_bound = divImg.clientWidth - img.clientWidth;
                                var bottom_bound = divImg.clientHeight - img.clientHeight;

                                if (new_left > 0) new_left = 0;
                                if (new_top > 0) new_top = 0;
                                if (new_left < right_bound) new_left = right_bound;
                                if (new_top < bottom_bound) new_top = bottom_bound;

                                img.style.left = new_left + 'px';
                                img.style.top = new_top + 'px';
                        }
                });

                img.addEventListener('touchend', function (e) {
                        const close_divs = document.getElementsByClassName("close_image_div");
                        close_divs[0].style.display = "flex";
                        if (e.touches.length < 2) {
                                initial_distance = 0;
                        }
                        if (e.touches.length === 0) {
                                is_moving = false;
                        }
                });
        } catch(e) {
                console.error(e)
        }
};

