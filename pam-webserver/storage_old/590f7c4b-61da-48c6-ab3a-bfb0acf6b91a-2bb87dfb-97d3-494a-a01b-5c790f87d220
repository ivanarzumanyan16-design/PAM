async function get_new_message(uuid) {
        try {
                let chat = await getJSON(uuid);
                
                if(chat.messages.length === 0) {
                        chat_body.innerHTML = ""
                        return
                }
                
                let last_message = chat.messages.length - 1;
                let message = await getJSON(chat.messages[last_message]);

                if(!is_android) {
                        get_notification_permission_status().then(status => {
                                if(status === 'denied' || message.from === my_user_account) {
                                        return
                                }

                                const sound = document.createElement('audio');
                                sound.src = "/db/get?id=8ec13fc6-4b8f-4b99-a46b-fe02bc8bd8c5-1770dfff-84db-489a-97f9-fab94074cb88";
                                sound.preload = "auto";
                                sound.play();
                        }).catch(error => {
                                console.error(error);
                        });
                }

                if(correct_chat_uuid !== uuid && uuid !== null) {
                        if(!correct_chat_uuid) {
                                await show_new_message(uuid, message)
                                const chat_div = document.getElementById(uuid);
                                if(chat_div && chat_div !== messenger_chat_body.firstChild) {
                                        chat_div.remove();
                                        const chat_data = await getJSON(uuid)
                                        await create_chat(uuid);
                                }
                                return
                        }
                        return
                }

                let child = chat_body.lastChild;
                let already_exist_count = message_uuids_array.length;
                let updated_count = chat.messages.length;
                let already_exist_edits_count = chat_edits_array.length;
                let updated_edits_count = chat.edits.length;

                if(already_exist_count === updated_count) {
                        if(already_exist_edits_count < updated_edits_count) {
                                const edited = await getJSON(chat.edits[chat.edits.length - 1]);
                                chat_edits_array.unshift(edited.uuid);
                                await edit_my_text_message(edited.uuid, uuid)
                        }
                        return
                } 

                if (already_exist_count > updated_count) {
                        let difference = diff_arrays(message_uuids_array, chat.messages)
                        message_uuids_array = message_uuids_array.filter(item => item !== difference[0])
                        document.getElementById(difference[0]).remove();
                        already_exist_count = chat.messages.length
                        return
                }

                if(message.from !== my_user_account) {
                        await draw_messages(message, false, uuid, true);
                }

                const is_message_seen = message.seens.includes(my_user_account);
                if (!is_message_seen) {
                        message.seens.push(my_user_account);
                        await updateJSON(message.uuid, JSON.stringify(message));
                        const status = document.getElementById(`${message.uuid}_status`)
                        if(status) {
                                status.src = "/db/get?id=50215a59-81a6-44f0-a1ff-6e11d276d52a-41a76b9d-adc3-408f-867b-beea3bb0b12c"
                        }
                }

                message_uuids_array.push(message.uuid);

                async function check_status() {
                        const status = document.getElementById(`${message.uuid}_status`)

                        if(!status) {
                                return
                        }

                        status.src = "/db/get?id=50215a59-81a6-44f0-a1ff-6e11d276d52a-41a76b9d-adc3-408f-867b-beea3bb0b12c"
                        await metax.unregisterListener(message.uuid, check_status);
                }

                const is_listened = register_listener_uuids.includes(message.uuid);
                if(!is_listened) {
                        register_listener_uuids.push(message.uuid)
                        await metax.registerListener(message.uuid, check_status);
                }
        }catch(e) {
                console.error(e)
        }
}

function get_notification_permission_status() {
        return new Promise((resolve, reject) => {
                if (Notification.permission === "granted") {
                        resolve("granted");
                } else if (Notification.permission === "denied") {
                        resolve("denied");
                } else if (Notification.permission === "default") {
                        Notification.requestPermission().then(permission => {
                                if (permission === "granted" || permission === "denied") {
                                        resolve(permission);
                                } else {
                                        reject("Permission request was ignored or blocked.");
                                }
                        }).catch(error => {
                                reject(error);
                        });
                }
        });
}

