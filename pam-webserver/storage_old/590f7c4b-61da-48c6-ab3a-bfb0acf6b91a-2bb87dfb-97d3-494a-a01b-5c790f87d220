                                                footer_div.style.height = input_message.scrollHeight + 33 + 'px';
                                                footer.style.height = input_message.scrollHeight + 33 + 'px';
                                                chat_body.style.bottom = input_message.scrollHeight + 33 + 'px';
                                                edit_div.style.bottom = (footer.offsetHeight) - 1 + 'px';

                                                chat_body.scrollTop = currentScrollTop + input_message.scrollHeight + 33;
                                        } else {
                                                edit_message.style.display = "none";
                                                edit_div.style.bottom = (footer.offsetHeight) + 'px';
                                                reset_input_styles()
                                        }
                                }

                                async function handle_edit_message_click() {
