                        const msg_from = await getJSON(last_msg_data.from);
                        chat_last_msg.id = `${details.uuid}_msg`;
                        chat_time.id = `${details.uuid}_time`;
                        chat_last_msg.textContent = `${msg_from.name}: ${last_msg_data.text || "Հաղորդագրութիւն"}`;

                        const message_date = new Date(last_msg_data.date);
                        const now = new Date();
                        const is_same_day = now.getFullYear() === message_date.getFullYear() &&
                              now.getMonth() === message_date.getMonth() &&
                              now.getDate() === message_date.getDate();

                        chat_time.textContent = is_same_day
                                ? create_time(last_msg_data.date)
