                                        edit_div.remove();

                                        edit_message.style.display = 'none';
                                        attach.style.display = 'block';
                                        record_message.style.display = 'block';

                                        input_message.style.height = '24px';
                                        message_div.style.height = '37px';
                                        footer.style.height = '65px';
                                        footer_div.style.height = '65px';
                                        chat_body.style.bottom = '65px';
                                        footer_div.style.paddingRight = '0';

                                        input_message.removeEventListener('input', input_settings);
                                        input_message.value = "";
                                });

                                edit_message.onclick = function(){handle_edit_message_click()}        

                                function input_settings() {
                                        submit_message.style.display = "none";
                                        if (input_message.value.trim().length > 0 ) {
                                                const currentScrollTop = chat_body.scrollTop;

                                                edit_message.style.display = "block";
                                                input_message.style.height = '24px';
                                                input_message.style.height = input_message.scrollHeight + 'px';
                                                message_div.style.height = input_message.scrollHeight + 5 + 'px';
