                const message_array = await Promise.all(message_promises);

                await Promise.all(message_array.map(async (message_data) => {
                        await draw_messages(message_data, false, chat_uuid, false);
                        await handle_message_status(message_data);
                }));

                let is_loading = false;
                let scroll_timeout;

                chat_body.addEventListener('scroll', async () => {
                        if (scroll_timeout) {
                                clearTimeout(scroll_timeout);
                        }

                        scroll_timeout = setTimeout(async () => {
                                if (chat_body.scrollTop <= 5 && !is_loading) {
                                        is_loading = true;
                                        await load_previous_messages();
                                        is_loading = false;
                                }
