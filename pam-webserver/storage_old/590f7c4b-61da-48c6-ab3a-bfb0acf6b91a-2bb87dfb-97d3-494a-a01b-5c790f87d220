                        chat_body.appendChild(message_element);
                } else {
                        chat_body.insertBefore(message_element, chat_body.firstChild);
                } 

                const update_message_element = async (details) => {
                        if (details.text !== undefined) {
                                message_element.innerHTML = "";
                                if (is_my_message) {
                                        create_my_text_message(details.text, details.date, details.uuid, is_new, chat_uuid, details.edited, details.seens);
                                } else {
                                        create_other_text_message(details.from, details.text, details.date, details.uuid, is_new, chat_uuid, details.edited);
                                }
                        } else if (details.voice_message !== undefined) {
                                message_element.innerHTML = "";
                                if (is_my_message) {
                                        create_my_voice_message(details.voice_message, details.date, details.voice_duration, details.uuid, is_new, chat_uuid, details.seens);
                                } else {
                                        create_other_voice_message(details.from, details.voice_message, details.date, details.voice_duration, details.uuid, is_new, chat_uuid);
                                }
                        } else if (details.file !== undefined) {
                                message_element.innerHTML = "";
                                if (is_my_message) {
                                        create_my_file_message(details.file, details.date, details.format, details.name, details.uuid, is_new, chat_uuid, details.seens);
                                } else {
                                        create_other_file_message(details.from, details.file, details.date, details.format, details.name, details.uuid, is_new, chat_uuid);
                                }
                        }
                        draw_date(details.is_first, is_new, details, new_msg, false)
                };

                update_message_element(message);
        } catch (e) {
                console.log(e);
        }
}

