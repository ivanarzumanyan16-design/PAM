    border: 1px solid #46804D;
    margin: 0;
    padding: 0;
    width: 800px;
    height: 600px;
    position: absolute;
}

#vostanAppMiddle {
    border: 1px solid #46804D;
    margin: 0;
    padding: 0;
    width: 1024px;
    height: 768px;
    position: absolute;
}

#vostanAppSize {
    color: #999900;
    font-size: 11px;
