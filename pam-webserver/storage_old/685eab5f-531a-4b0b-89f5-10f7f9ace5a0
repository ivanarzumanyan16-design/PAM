/**********************************/

body, h1, h2, h3, h4, h5, h6 {
        font-family: VostanGrapalat !important;
}

html, body {
    color: #333;
    font-family: VostanSans, VostanCantarell, VostanGrapalat, "Arian AMU", "Arial AMU", "GHEA Grapalat", Sylfaen, sans-serif !important;
    font-size: 13px !important;
    height: 100%;
    margin: 0;
    overflow: hidden;
    padding: 0;
}

body.wait, body.wait node {
    cursor: wait !important;
}

body.connect, body.connect node {
    cursor: alias !important;
}

.h-line {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1;
    border-top: 1px #CC3333 solid;
}

.v-line {
    position: absolute;
    top: 0;
    left: 0;
    width: 1;
    bottom: 0;
    border-left: 1px #CC3333 solid;
}

node {
    -webkit-tap-highlight-color: rgba(0,0,0,0);
    -webkit-touch-callout: none;
    -webkit-user-select: none;
    -khtml-user-select: none;
    -moz-user-select: -moz-none;
    -o-user-select: none;
    user-select: none;
    background-color: #fff;
    border: 1px #666666 solid;
    border-radius: 5px;
    cursor: pointer;
}

::-webkit-scrollbar
{
    width: 3px;
    height: 3px;
    background-color: #000;
}

::-webkit-scrollbar-track
{
    -webkit-box-shadow: inset 0 0 3px rgba(f,f,f,0.3);
    background-color: #fff;
}

::-webkit-scrollbar-thumb
{
    background-color: #000;
}

node.node-root, node.leaf {
    cursor: auto;
}

node.node-root .info, node.node-root .par, node.leaf .info, node.leaf .par {
    -webkit-user-select: text;
    -khtml-user-select: text;
    -moz-user-select: text;
    -o-user-select: text;
    user-select: text;
    cursor: text;
}

div.query-nodes node .info,
div.query-nodes node .img,
div#carousel-items node .info,
div#carousel-items node .img {
    -webkit-user-select: none;
    -khtml-user-select: none;
    -moz-user-select: none;
    -o-user-select: none;
    user-select: none;
    cursor: pointer;
}

node.node-root .img, node.leaf .img {
    cursor: text;
}

#vostanApp  node.active {
    border-color: #666;
    background-color: #F5B571;
}

#viewTab {
    height: 100%;
    overflow-y: auto;
}

#vostanContainer {
}

#viewTab.editMode {
    background-color: #fff;
}

#vostanApp {
    border: 1px solid #46804D;
    padding: 0;
    width: 1024px;
    height: 768px;
    position: relative;
}

#vostanApp.presentation, #vostanApp.presentation #vostanAppSmall, #vostanApp.presentation #vostanAppMiddle {
    border: none;
}

#vostanApp.presentation #vostanAppSize, #vostanApp.presentation #vostanAppSmallSize,  #vostanApp.presentation #vostanAppMiddleSize, #vostanMain {
    display: none;
}

