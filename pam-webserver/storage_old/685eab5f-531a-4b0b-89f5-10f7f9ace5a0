    padding: 0;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
}

#vostanControls img {
    cursor: pointer;
}

#vostanApp node {
    padding: 0;
    position: absolute;
    display: block;
    overflow: hidden;
    border: 1px #666 solid;
    background-color: #fff;
    border-radius: 5px;
}

#vostanApp node.node-proot,
#vostanApp node.node-root {
}

